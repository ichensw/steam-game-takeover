page {
  min-height: 100vh;
  background: #160750;
  color: #ffffff;
}

button::after {
  border: 0;
}

.profile-page {
  position: relative;
  min-height: 100vh;
}

.profile-bg {
  position: fixed;
  inset: 0;
  width: 100vw;
  height: 100vh;
  z-index: 0;
}

.profile-shade {
  position: fixed;
  inset: 0;
  z-index: 1;
  background: linear-gradient(180deg, rgba(13, 4, 58, 0.05), rgba(22, 7, 80, 0.24) 48%, rgba(22, 7, 80, 0.62));
}

.profile-shell {
  position: relative;
  z-index: 2;
  min-height: 100vh;
  padding: 78rpx 34rpx 72rpx;
  box-sizing: border-box;
}

.profile-nav {
  height: 72rpx;
  display: flex;
  align-items: center;
}

.back-button {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.16);
  color: #ffffff;
  font-size: 56rpx;
  line-height: 56rpx;
  box-shadow: 0 0 22rpx rgba(255, 118, 238, 0.32);
  backdrop-filter: blur(14rpx);
}

.hero {
  margin-top: 136rpx;
  display: flex;
  align-items: center;
  gap: 30rpx;
}

.avatar-ring {
  position: relative;
  width: 214rpx;
  height: 214rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 8rpx solid rgba(255, 118, 252, 0.95);
  border-radius: 50%;
  box-shadow: 0 0 34rpx rgba(255, 77, 255, 0.72);
  background: rgba(255, 255, 255, 0.1);
  box-sizing: border-box;
}

.avatar {
  width: 184rpx;
  height: 184rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
}

.hero-copy {
  min-width: 0;
  flex: 1;
}

.nickname {
  display: block;
  max-width: 420rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #ffffff;
  font-size: 48rpx;
  line-height: 1.25;
  font-weight: 900;
  text-shadow: 0 0 18rpx rgba(139, 92, 246, 0.4);
}

.steam-row {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 29rpx;
  font-weight: 600;
}

.copy-mini {
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  color: #ffffff;
  font-size: 22rpx;
}

.stats-panel {
  margin-top: 52rpx;
  height: 148rpx;
  display: flex;
  align-items: center;
  border: 2rpx solid rgba(255, 255, 255, 0.28);
  border-radius: 28rpx;
  background: rgba(190, 105, 255, 0.44);
  box-shadow: 0 0 28rpx rgba(255, 141, 244, 0.34);
  backdrop-filter: blur(18rpx);
}

.stat-item {
  min-width: 0;
  flex: 1;
  display: grid;
  grid-template-columns: 62rpx 1fr;
  grid-template-rows: 48rpx 34rpx;
  column-gap: 12rpx;
  align-items: center;
  justify-content: center;
  padding: 0 18rpx;
  box-sizing: border-box;
}

.stat-icon {
  grid-row: 1 / 3;
  justify-self: center;
  width: 62rpx;
  height: 62rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.profile-edit-button {
  position: absolute;
  right: 4rpx;
  bottom: 20rpx;
  width: 58rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 8rpx 20rpx rgba(82, 24, 154, 0.32);
}

.profile-edit-icon {
  width: 28rpx;
  height: 28rpx;
}

.stat-emoji {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  height: 42rpx;
  font-size: 36rpx;
  line-height: 1;
  transform: translateY(-3rpx);
}

.stat-emoji-target {
  transform: translate(3rpx, -3rpx);
}

.stat-pink {
  background: #ff5cb9;
}

.stat-purple {
  background: #7c3cff;
}

.stat-credit {
  background: linear-gradient(135deg, #20c97a 0%, #12b6cb 100%);
  box-shadow: 0 0 18rpx rgba(34, 197, 94, 0.34);
}

.stat-credit-icon {
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  transform: translateY(-2rpx);
}

.credit-limited .stat-credit {
  background: linear-gradient(135deg, #f59e0b 0%, #f97316 100%);
  box-shadow: 0 0 18rpx rgba(245, 158, 11, 0.3);
}

.credit-disabled .stat-credit {
  background: linear-gradient(135deg, #292524 0%, #7f1d1d 100%);
  box-shadow: 0 0 18rpx rgba(127, 29, 29, 0.3);
}

.credit-stat {
  border-radius: 22rpx;
}

.credit-stat.credit-limited {
  background: rgba(245, 158, 11, 0.1);
}

.credit-stat.credit-disabled {
  background: rgba(127, 29, 29, 0.12);
}

.stat-value,
.stat-label {
  display: block;
}

.stat-value {
  color: #ffffff;
  font-size: 36rpx;
  line-height: 44rpx;
  font-weight: 900;
}

.stat-label {
  color: rgba(255, 255, 255, 0.82);
  font-size: 22rpx;
  line-height: 30rpx;
  font-weight: 600;
}

.stat-divider {
  width: 2rpx;
  height: 78rpx;
  background: rgba(255, 255, 255, 0.3);
}

.profile-completion-card {
  position: relative;
  overflow: visible;
  margin-top: 24rpx;
  padding: 24rpx 24rpx 22rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.46);
  border-radius: 28rpx;
  background: linear-gradient(135deg, rgba(255, 244, 255, 0.9), rgba(236, 221, 255, 0.86));
  box-shadow: 0 14rpx 30rpx rgba(62, 24, 128, 0.2);
  backdrop-filter: blur(18rpx);
  animation: profileCompletionIn 360ms ease-out both;
}

.profile-completion-complete {
  border-color: rgba(255, 255, 255, 0.58);
  background: linear-gradient(135deg, rgba(255, 246, 255, 0.94), rgba(232, 218, 255, 0.9));
  box-shadow: 0 16rpx 34rpx rgba(98, 45, 174, 0.2), 0 0 24rpx rgba(255, 92, 185, 0.14);
}

.profile-completion-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.profile-completion-badge {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 50%;
  background: linear-gradient(135deg, #7c3cff 0%, #ff3fa7 100%);
  color: #ffffff;
  font-size: 30rpx;
  line-height: 52rpx;
  font-weight: 900;
  box-shadow: 0 8rpx 20rpx rgba(255, 63, 167, 0.28);
}

.profile-completion-complete .profile-completion-badge {
  background: linear-gradient(135deg, #8b5cf6 0%, #ff73c7 100%);
  color: #ffffff;
  box-shadow: 0 10rpx 22rpx rgba(139, 92, 246, 0.22);
  animation: profileCompletionPop 520ms cubic-bezier(0.2, 1.2, 0.28, 1) both;
}

.profile-completion-copy {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.profile-completion-title {
  color: #351556;
  font-size: 30rpx;
  line-height: 38rpx;
  font-weight: 900;
}

.profile-completion-desc {
  color: rgba(53, 21, 86, 0.6);
  font-size: 24rpx;
  line-height: 32rpx;
  font-weight: 700;
}

.profile-completion-score {
  display: block;
  text-align: right;
  flex-shrink: 0;
  color: #7c3cff;
  font-size: 42rpx;
  line-height: 48rpx;
  font-weight: 900;
}

.profile-completion-complete .profile-completion-score {
  color: #7c3cff;
}

.profile-completion-side {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.profile-completion-complete .profile-completion-side {
  padding-right: 16rpx;
}

.profile-completion-close {
  position: absolute;
  top: -14rpx;
  right: -10rpx;
  z-index: 2;
  width: 50rpx;
  height: 50rpx;
  display: block;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.66);
  background: rgba(255, 255, 255, 0.9);
  color: rgba(53, 21, 86, 0.66);
  font-size: 34rpx;
  line-height: 46rpx;
  font-weight: 800;
  text-align: center;
  box-shadow: 0 8rpx 18rpx rgba(53, 21, 86, 0.12);
  backdrop-filter: blur(10rpx);
}

.profile-completion-complete .profile-completion-close {
  background: rgba(255, 255, 255, 0.92);
  color: rgba(124, 60, 255, 0.68);
}

.profile-completion-bar {
  position: relative;
  margin-top: 20rpx;
  height: 16rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: rgba(124, 60, 255, 0.14);
}

.profile-completion-complete .profile-completion-bar {
  background: rgba(124, 60, 255, 0.14);
}

.profile-completion-progress {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #7c3cff 0%, #ff5cb9 100%);
  transition: width 320ms ease, background 260ms ease;
}

.profile-completion-complete .profile-completion-progress {
  background: linear-gradient(90deg, #8b5cf6 0%, #c65cff 54%, #ff73c7 100%);
}

.profile-completion-shine {
  position: absolute;
  top: 0;
  left: -40%;
  width: 38%;
  height: 100%;
  transform: skewX(-24deg);
  background: rgba(255, 255, 255, 0.58);
  animation: profileCompletionShine 900ms ease-out 180ms both;
}

.profile-completion-foot {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.profile-completion-tag {
  flex-shrink: 0;
  padding: 7rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(124, 60, 255, 0.12);
  color: #6d28d9;
  font-size: 21rpx;
  line-height: 28rpx;
  font-weight: 900;
}

.profile-completion-complete .profile-completion-tag {
  background: rgba(124, 60, 255, 0.12);
  color: #6d28d9;
}

.profile-completion-tip {
  min-width: 0;
  flex: 1;
  color: rgba(53, 21, 86, 0.45);
  font-size: 22rpx;
  line-height: 30rpx;
  font-weight: 700;
}

.profile-completion-action {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(124, 60, 255, 0.12);
  color: #6d28d9;
  font-size: 23rpx;
  line-height: 30rpx;
  font-weight: 900;
}

.profile-completion-complete .profile-completion-action {
  background: rgba(255, 92, 185, 0.14);
  color: #7c3cff;
}

.section {
  margin-top: 34rpx;
  padding: 28rpx 20rpx 24rpx;
  border-radius: 28rpx;
  background: rgba(159, 78, 232, 0.36);
  box-shadow: 0 0 26rpx rgba(189, 104, 255, 0.28);
  backdrop-filter: blur(16rpx);
}

.section-head {
  height: 54rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.section-title {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 900;
}

.section-more {
  color: rgba(255, 255, 255, 0.9);
  font-size: 26rpx;
  font-weight: 800;
}

.empty-card {
  border-radius: 26rpx;
  background: rgba(255, 241, 255, 0.94);
  box-shadow: 0 12rpx 28rpx rgba(62, 24, 128, 0.18);
}

.takeover-card-wrap {
  margin-top: 18rpx;
}

.empty-card {
  height: 150rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(29, 21, 61, 0.58);
  font-size: 26rpx;
  font-weight: 700;
}

.feedback-entry {
  margin-top: 24rpx;
  min-height: 112rpx;
  padding: 20rpx 22rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.54);
  border-radius: 28rpx;
  background: rgba(255, 244, 255, 0.78);
  box-shadow: 0 12rpx 28rpx rgba(62, 24, 128, 0.2);
  box-sizing: border-box;
}

.feedback-icon {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 50%;
  background: linear-gradient(135deg, #7c3cff 0%, #ff5cb9 100%);
  color: #ffffff;
  font-size: 34rpx;
  line-height: 64rpx;
  font-weight: 900;
}

.feedback-copy {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.feedback-title {
  color: #351556;
  font-size: 28rpx;
  line-height: 36rpx;
  font-weight: 900;
}

.feedback-desc {
  color: rgba(53, 21, 86, 0.52);
  font-size: 23rpx;
  line-height: 30rpx;
  font-weight: 700;
}

.feedback-arrow {
  flex-shrink: 0;
  color: rgba(53, 21, 86, 0.42);
  font-size: 44rpx;
  line-height: 44rpx;
  font-weight: 900;
}

.global-loading {
  position: fixed;
  inset: 0;
  z-index: 8;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.loading-card {
  min-width: 168rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  border-radius: 22rpx;
  background: rgba(24, 27, 37, 0.88);
}

.loading-spinner {
  width: 30rpx;
  height: 30rpx;
  border: 4rpx solid rgba(247, 248, 255, 0.18);
  border-top-color: #f9a8ff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.loading-text {
  color: rgba(247, 248, 255, 0.86);
  font-size: 24rpx;
  font-weight: 600;
}

@keyframes profileCompletionIn {
  from {
    opacity: 0;
    transform: translateY(14rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes profileCompletionPop {
  0% {
    transform: scale(0.72);
  }

  62% {
    transform: scale(1.12);
  }

  100% {
    transform: scale(1);
  }
}

@keyframes profileCompletionShine {
  from {
    left: -42%;
  }

  to {
    left: 112%;
  }
}

@keyframes spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}
