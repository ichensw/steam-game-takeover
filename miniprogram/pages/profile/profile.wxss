page {
  min-height: 100vh;
  background: #160750;
  color: #ffffff;
}

button::after {
  border: 0;
}

.profile-page {
  position: relative;
  min-height: 100vh;
}

.profile-bg {
  position: fixed;
  inset: 0;
  width: 100vw;
  height: 100vh;
  z-index: 0;
}

.profile-shade {
  position: fixed;
  inset: 0;
  z-index: 1;
  background: linear-gradient(180deg, rgba(13, 4, 58, 0.05), rgba(22, 7, 80, 0.24) 48%, rgba(22, 7, 80, 0.62));
}

.profile-shell {
  position: relative;
  z-index: 2;
  min-height: 100vh;
  padding: 78rpx 34rpx 72rpx;
  box-sizing: border-box;
}

.profile-nav {
  height: 72rpx;
  display: flex;
  align-items: center;
}

.back-button {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.16);
  color: #ffffff;
  font-size: 56rpx;
  line-height: 56rpx;
  box-shadow: 0 0 22rpx rgba(255, 118, 238, 0.32);
  backdrop-filter: blur(14rpx);
}

.hero {
  margin-top: 136rpx;
  display: flex;
  align-items: center;
  gap: 30rpx;
}

.avatar-ring {
  position: relative;
  width: 214rpx;
  height: 214rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 8rpx solid rgba(255, 118, 252, 0.95);
  border-radius: 50%;
  box-shadow: 0 0 34rpx rgba(255, 77, 255, 0.72);
  background: rgba(255, 255, 255, 0.1);
  box-sizing: border-box;
}

.avatar {
  width: 184rpx;
  height: 184rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
}

.hero-copy {
  min-width: 0;
  flex: 1;
}

.nickname {
  display: block;
  max-width: 420rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #ffffff;
  font-size: 48rpx;
  line-height: 1.25;
  font-weight: 900;
  text-shadow: 0 0 18rpx rgba(139, 92, 246, 0.4);
}

.steam-row {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 29rpx;
  font-weight: 600;
}

.copy-mini {
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  color: #ffffff;
  font-size: 22rpx;
}

.stats-panel {
  margin-top: 52rpx;
  height: 148rpx;
  display: flex;
  align-items: center;
  border: 2rpx solid rgba(255, 255, 255, 0.28);
  border-radius: 28rpx;
  background: rgba(190, 105, 255, 0.44);
  box-shadow: 0 0 28rpx rgba(255, 141, 244, 0.34);
  backdrop-filter: blur(18rpx);
}

.stat-item {
  min-width: 0;
  flex: 1;
  display: grid;
  grid-template-columns: 62rpx 1fr;
  grid-template-rows: 48rpx 34rpx;
  column-gap: 12rpx;
  align-items: center;
  justify-content: center;
  padding: 0 18rpx;
  box-sizing: border-box;
}

.stat-icon {
  grid-row: 1 / 3;
  justify-self: center;
  width: 62rpx;
  height: 62rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.profile-edit-button {
  position: absolute;
  right: 4rpx;
  bottom: 20rpx;
  width: 58rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 8rpx 20rpx rgba(82, 24, 154, 0.32);
}

.profile-edit-icon {
  width: 28rpx;
  height: 28rpx;
}

.stat-emoji {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  height: 42rpx;
  font-size: 36rpx;
  line-height: 1;
  transform: translateY(-3rpx);
}

.stat-emoji-target {
  transform: translate(3rpx, -3rpx);
}

.stat-pink {
  background: #ff5cb9;
}

.stat-purple {
  background: #7c3cff;
}

.stat-credit {
  background: linear-gradient(135deg, #20c97a 0%, #12b6cb 100%);
  box-shadow: 0 0 18rpx rgba(34, 197, 94, 0.34);
}

.stat-credit-icon {
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  transform: translateY(-2rpx);
}

.credit-limited .stat-credit {
  background: linear-gradient(135deg, #f59e0b 0%, #f97316 100%);
  box-shadow: 0 0 18rpx rgba(245, 158, 11, 0.3);
}

.credit-disabled .stat-credit {
  background: linear-gradient(135deg, #292524 0%, #7f1d1d 100%);
  box-shadow: 0 0 18rpx rgba(127, 29, 29, 0.3);
}

.credit-stat {
  border-radius: 22rpx;
}

.credit-stat.credit-limited {
  background: rgba(245, 158, 11, 0.1);
}

.credit-stat.credit-disabled {
  background: rgba(127, 29, 29, 0.12);
}

.stat-value,
.stat-label {
  display: block;
}

.stat-value {
  color: #ffffff;
  font-size: 36rpx;
  line-height: 44rpx;
  font-weight: 900;
}

.stat-label {
  color: rgba(255, 255, 255, 0.82);
  font-size: 22rpx;
  line-height: 30rpx;
  font-weight: 600;
}

.stat-divider {
  width: 2rpx;
  height: 78rpx;
  background: rgba(255, 255, 255, 0.3);
}

.section {
  margin-top: 34rpx;
  padding: 28rpx 20rpx 24rpx;
  border-radius: 28rpx;
  background: rgba(159, 78, 232, 0.36);
  box-shadow: 0 0 26rpx rgba(189, 104, 255, 0.28);
  backdrop-filter: blur(16rpx);
}

.section-head {
  height: 54rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.section-title {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 900;
}

.section-more {
  color: rgba(255, 255, 255, 0.9);
  font-size: 26rpx;
  font-weight: 800;
}

.empty-card {
  border-radius: 26rpx;
  background: rgba(255, 241, 255, 0.94);
  box-shadow: 0 12rpx 28rpx rgba(62, 24, 128, 0.18);
}

.takeover-card-wrap {
  margin-top: 18rpx;
}

.empty-card {
  height: 150rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(29, 21, 61, 0.58);
  font-size: 26rpx;
  font-weight: 700;
}

.global-loading {
  position: fixed;
  inset: 0;
  z-index: 8;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.loading-card {
  min-width: 168rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  border-radius: 22rpx;
  background: rgba(24, 27, 37, 0.88);
}

.loading-spinner {
  width: 30rpx;
  height: 30rpx;
  border: 4rpx solid rgba(247, 248, 255, 0.18);
  border-top-color: #f9a8ff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.loading-text {
  color: rgba(247, 248, 255, 0.86);
  font-size: 24rpx;
  font-weight: 600;
}

@keyframes spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}
