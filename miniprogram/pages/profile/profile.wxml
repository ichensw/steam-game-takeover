<scroll-view class="profile-page" scroll-y>
  <image class="profile-bg" src="{{backgroundUrl}}" mode="aspectFill"></image>
  <view class="profile-shade"></view>

  <view class="profile-shell">
    <view class="profile-nav">
      <view class="back-button" bindtap="goBack">‹</view>
    </view>

    <view class="hero">
      <view class="avatar-ring" bindtap="openProfileSheet">
        <image class="avatar" src="{{user.avatarUrl || femaleAvatarUrl}}" mode="aspectFill"></image>
        <view class="profile-edit-button" wx:if="{{user.nickname && user.gender}}" bindtap="openProfileSheet">
          <image class="profile-edit-icon" src="/assets/edit.svg" mode="aspectFit"></image>
        </view>
      </view>
      <view class="hero-copy">
        <text class="nickname" bindtap="openProfileSheet">{{user.nickname || '兔兔玩家'}}</text>
        <view class="steam-row">
          <text>ID：{{user.steamId || '未填写'}}</text>
          <view class="copy-mini" wx:if="{{user.steamId}}" bindtap="copySteamId">复制</view>
        </view>
      </view>
    </view>

    <view class="stats-panel">
      <view class="stat-item">
        <view class="stat-icon stat-pink"><image class="stat-emoji stat-gamepad-icon" src="/assets/icon-gamepad.svg" mode="aspectFit"></image></view>
        <text class="stat-value">{{createdCount}}</text>
        <text class="stat-label">发起接龙</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <view class="stat-icon stat-purple"><image class="stat-emoji stat-participate-icon" src="/assets/icon-participate.svg" mode="aspectFit"></image></view>
        <text class="stat-value">{{joinedCount}}</text>
        <text class="stat-label">参与接龙</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item credit-stat credit-{{user.creditStatus}}" bindtap="openCreditHelp">
        <view class="stat-icon stat-credit">
          <image class="stat-credit-icon" src="/assets/icon-credit.svg" mode="aspectFill"></image>
        </view>
        <text class="stat-value">{{user.creditScore}}</text>
        <text class="stat-label">信誉分</text>
      </view>
    </view>

    <view class="credit-card credit-card-{{user.creditStatus}}">
      <view class="credit-card-main" bindtap="openCreditHelp">
        <view class="credit-card-copy">
          <text class="credit-card-title">{{creditInfo.title}}</text>
          <text class="credit-card-desc">{{creditInfo.desc}}</text>
        </view>
        <text class="credit-card-badge" wx:if="{{creditInfo.badge}}">{{creditInfo.badge}}</text>
      </view>
      <view class="credit-card-actions">
        <view class="credit-card-action" bindtap="openCreditHelp">信誉说明</view>
        <view class="credit-card-action" bindtap="openCreditLogs">信誉记录</view>
      </view>
    </view>

    <view class="profile-completion-card profile-completion-{{profileCompletion.status}}" wx:if="{{showProfileCompletion}}" bindtap="openProfileCompletion">
      <view class="profile-completion-close" wx:if="{{profileCompletion.score >= 100}}" catchtap="closeProfileCompletion">×</view>
      <view class="profile-completion-main">
        <view class="profile-completion-badge">{{profileCompletion.badge}}</view>
        <view class="profile-completion-copy">
          <text class="profile-completion-title">{{profileCompletion.title}}</text>
          <text class="profile-completion-desc">{{profileCompletion.message}}</text>
        </view>
        <view class="profile-completion-side">
          <text class="profile-completion-score">{{profileCompletion.score}}%</text>
        </view>
      </view>
      <view class="profile-completion-bar">
        <view class="profile-completion-progress" style="width: {{profileCompletion.score}}%;"></view>
        <view class="profile-completion-shine" wx:if="{{profileCompletion.score >= 100}}"></view>
      </view>
      <view class="profile-completion-foot">
        <text class="profile-completion-tag">{{profileCompletion.tag}}</text>
        <text class="profile-completion-tip">{{profileCompletion.tip}}</text>
        <text class="profile-completion-action">{{profileCompletion.actionLabel}} ›</text>
      </view>
    </view>

    <view class="section">
      <view class="section-head" bindtap="openMyTakeovers">
        <text class="section-title">我的接龙</text>
        <text class="section-more">全部 ›</text>
      </view>

      <view class="takeover-card-wrap" wx:for="{{recent}}" wx:key="id">
        <takeover-card takeover="{{item}}" bindtapcard="openTakeover"></takeover-card>
      </view>

      <view class="empty-card" wx:if="{{!recent.length && !isLoading}}">
        <text>还没有接龙记录</text>
      </view>
    </view>

    <view class="feedback-actions">
      <view class="feedback-entry" bindtap="openFeedback">
        <view class="feedback-icon">✎</view>
        <view class="feedback-copy">
          <text class="feedback-title">提交反馈</text>
          <text class="feedback-desc">遇到问题或有建议</text>
        </view>
        <text class="feedback-arrow">›</text>
      </view>
      <view class="feedback-entry" bindtap="openMyFeedbacks">
        <view class="feedback-icon feedback-icon-muted">✓</view>
        <view class="feedback-copy">
          <text class="feedback-title">我的反馈</text>
          <text class="feedback-desc">查看处理状态</text>
        </view>
        <text class="feedback-arrow">›</text>
      </view>
      <view class="feedback-entry" bindtap="openBlockedUsers">
        <view class="feedback-icon feedback-icon-block">×</view>
        <view class="feedback-copy">
          <text class="feedback-title">黑名单列表</text>
          <text class="feedback-desc">管理不能加入你队伍的玩家</text>
        </view>
        <text class="feedback-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="global-loading" wx:if="{{isLoading}}">
    <view class="loading-card">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中</text>
    </view>
  </view>

  <profile-sheet
    visible="{{showProfileSheet}}"
    mode="{{profileMode}}"
    nickname="{{editNickname}}"
    steam-id="{{editSteamId}}"
    steam-id-locked="{{false}}"
    gender="{{editGender}}"
    avatar-url="{{editAvatarUrl}}"
    male-avatar-url="{{maleAvatarUrl}}"
    female-avatar-url="{{femaleAvatarUrl}}"
    nickname-error="{{editNicknameError}}"
    steam-id-error="{{editSteamIdError}}"
    gender-error="{{editGenderError}}"
    is-uploading="{{isUploadingAvatar}}"
    is-saving="{{isSavingProfile}}"
    bindclose="closeProfileSheet"
    bindchooseavatar="chooseAvatar"
    bindselectgender="selectGender"
    bindnicknameinput="handleNicknameInput"
    bindsteamidinput="handleSteamIdInput"
    bindsave="saveProfile"
  />

  <view class="credit-help-mask" wx:if="{{showCreditHelp}}" bindtap="closeCreditHelp"></view>
  <view class="credit-help-sheet" wx:if="{{showCreditHelp}}">
    <view class="credit-help-title-row">
      <text class="credit-help-title">信誉分说明</text>
      <view class="credit-help-close" bindtap="closeCreditHelp">×</view>
    </view>
    <view class="credit-help-row">
      <text class="credit-help-score">70+</text>
      <text class="credit-help-copy">可正常加入接龙</text>
    </view>
    <view class="credit-help-row">
      <text class="credit-help-score">51-69</text>
      <text class="credit-help-copy">加入接龙会受限</text>
    </view>
    <view class="credit-help-row">
      <text class="credit-help-score">≤50</text>
      <text class="credit-help-copy">暂不可参与接龙</text>
    </view>
    <text class="credit-help-note">举报核实、失约或违规行为可能影响信誉分；管理员处理后可恢复。</text>
  </view>

  <view class="blocked-users-mask" wx:if="{{showBlockedUsersSheet}}" bindtap="closeBlockedUsers"></view>
  <view class="blocked-users-sheet" wx:if="{{showBlockedUsersSheet}}">
    <view class="blocked-users-title-row">
      <text class="blocked-users-title">黑名单列表</text>
      <view class="blocked-users-close" bindtap="closeBlockedUsers">×</view>
    </view>

    <view class="blocked-users-loading" wx:if="{{isLoadingBlockedUsers}}">加载中</view>
    <view class="blocked-users-empty" wx:elif="{{!blockedUsers.length}}">还没有拉黑的玩家</view>
    <view class="blocked-user-row" wx:if="{{!isLoadingBlockedUsers && blockedUsers.length}}" wx:for="{{blockedUsers}}" wx:key="id">
      <image class="blocked-user-avatar" src="{{item.avatarUrl || femaleAvatarUrl}}" mode="aspectFill"></image>
      <view class="blocked-user-copy">
        <text class="blocked-user-name">{{item.nickname || '兔兔玩家'}}</text>
        <text class="blocked-user-steam">SteamID：{{item.steamId || '未填写'}}</text>
      </view>
      <button class="blocked-user-action" loading="{{unblockingUserId === item.id}}" disabled="{{unblockingUserId}}" data-userid="{{item.id}}" data-nickname="{{item.nickname || '该玩家'}}" bindtap="unblockUser">解除</button>
    </view>
  </view>
</scroll-view>
