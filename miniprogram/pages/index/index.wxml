<scroll-view
  class="page"
  scroll-y
  type="list"
  refresher-enabled
  refresher-triggered="{{isRefreshing}}"
  lower-threshold="100"
  bindrefresherrefresh="refreshTakeovers"
  bindscrolltolower="loadMoreTakeovers"
>
  <image class="page-bg" src="https://wechat-bot-images.oss-cn-hangzhou.aliyuncs.com/miniapp/background/tutuwo-neon-bg.png" mode="aspectFill"></image>
  <view class="page-vignette"></view>
  <view class="shell">
    <view class="filter-panel">
      <view class="search-box">
        <input
          class="search-input"
          value="{{searchKeyword}}"
          placeholder="搜索标题 / 内容 / 发起人"
          placeholder-class="placeholder"
          bindinput="handleSearchInput"
        />
        <text class="search-icon" wx:if="{{!searchKeyword}}">⌕</text>
        <view class="search-clear" wx:else bindtap="clearSearch">
          <view class="search-clear-line search-clear-line-a"></view>
          <view class="search-clear-line search-clear-line-b"></view>
        </view>
      </view>

      <view class="filter-actions">
        <view class="time-filter {{activeTimeFilter === 'all' ? 'time-filter-active' : ''}}" bindtap="selectAllTimeFilter">全部</view>
        <view class="time-filter time-filter-select {{activeTimeFilter !== 'all' ? 'time-filter-active' : ''}}" bindtap="toggleTimeFilterDropdown">
          <text>{{activeTimeFilterLabel}}</text>
          <view class="filter-caret {{showTimeFilterDropdown ? 'filter-caret-open' : ''}}"></view>
        </view>
      </view>

      <view class="time-dropdown" wx:if="{{showTimeFilterDropdown}}">
        <view
          class="time-dropdown-item {{activeTimeFilter === item.value ? 'time-dropdown-active' : ''}}"
          wx:for="{{timeFilters}}"
          wx:key="value"
          data-value="{{item.value}}"
          bindtap="selectTimeFilter"
        >
          {{item.label}}
        </view>
      </view>

      <view class="range-filter-panel" wx:if="{{activeTimeFilter === 'range'}}">
        <picker mode="date" value="{{rangeStartDate}}" start="{{todayDate}}" bindchange="handleRangeStartChange">
          <view class="range-picker">
            <text class="range-picker-label">开始</text>
            <text class="range-picker-value">{{rangeStartDate || '选择日期'}}</text>
          </view>
        </picker>
        <picker mode="date" value="{{rangeEndDate}}" start="{{rangeStartDate || todayDate}}" bindchange="handleRangeEndChange">
          <view class="range-picker">
            <text class="range-picker-label">结束</text>
            <text class="range-picker-value">{{rangeEndDate || '选择日期'}}</text>
          </view>
        </picker>
        <view class="range-clear" wx:if="{{rangeStartDate || rangeEndDate}}" bindtap="clearRangeFilter">清空日期</view>
      </view>
    </view>

    <view class="takeover-list">
      <view class="takeover-card takeover-card-{{item.statusTone}}" wx:for="{{takeoverList}}" wx:key="id" data-id="{{item.id}}" bindtap="viewTakeover">
        <image class="card-cover" src="{{item.coverImage}}" mode="aspectFit"></image>
        <view class="card-ambient"></view>
        <view class="card-sparkle card-sparkle-one">✦</view>
        <view class="card-sparkle card-sparkle-two">♡</view>
        <view class="game-badge">
          <text class="game-icon">🎮</text>
          <text>{{item.categoryLabel}}</text>
        </view>
        <view class="status-badge status-{{item.statusTone}}">{{item.statusLabel}}</view>
        <view class="card-head">
          <text class="card-title">{{item.title}}</text>
        </view>

        <view class="card-note">
          <text class="note-text">{{item.description}}</text>
        </view>

        <view class="card-meta-list">
          <view class="card-meta-row">
            <view class="meta-icon">
              <image class="meta-icon-image" src="/assets/icon-time.svg" mode="aspectFit"></image>
            </view>
            <text class="meta-value">{{item.scheduleText}}</text>
          </view>
          <view class="card-meta-row">
            <view class="meta-icon">
              <image class="meta-icon-image" src="/assets/icon-host.svg" mode="aspectFit"></image>
            </view>
            <text class="meta-value">{{item.host || '兔兔窝'}}</text>
          </view>
          <view class="card-meta-row">
            <view class="meta-icon">
              <image class="meta-icon-image" src="/assets/icon-members.svg" mode="aspectFit"></image>
            </view>
            <text class="meta-value">{{item.joined}} / {{item.limit}}</text>
          </view>
        </view>

        <view class="card-foot">
          <view class="member-side">
            <view class="avatar-stack">
              <image
                class="member-avatar"
                wx:for="{{item.participantAvatars}}"
                wx:for-item="avatar"
                wx:key="*this"
                src="{{avatar}}"
                mode="aspectFill"
              ></image>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:if="{{isBlocked}}">
      <text>{{blockedMessage || '您已被管理员拉黑'}}</text>
    </view>

    <view class="empty-state" wx:elif="{{!takeoverList.length && !isRefreshing}}">
      <text>没有找到合适的接龙</text>
    </view>

    <view class="list-footer" wx:if="{{takeoverList.length && !isRefreshing}}">
      <text wx:if="{{isLoadingMore}}">加载中...</text>
      <text wx:elif="{{!hasMore}}">已经到底啦</text>
      <button wx:else class="load-more-button" bindtap="loadMoreTakeovers">加载更多</button>
    </view>

  </view>
</scroll-view>

<button class="create-dock" bindtap="createTakeover">
  <text class="create-dock-plus">＋</text>
  <text>发起接龙</text>
</button>

<view class="profile-float" bindtap="openProfileEditor">
  <image class="profile-float-avatar" src="{{avatarUrl || femaleAvatarUrl}}" mode="aspectFill"></image>
</view>

<view class="global-loading" wx:if="{{isAuthorizing}}">
  <view class="loading-card">
    <view class="loading-spinner"></view>
    <text class="loading-text">处理中</text>
  </view>
</view>

<view class="sheet-mask" wx:if="{{showProfileSheet}}" bindtap="closeProfileSheet"></view>
<view class="profile-sheet" wx:if="{{showProfileSheet}}">
  <view class="sheet-handle"></view>
  <view class="sheet-title-row">
    <text class="sheet-title">补充资料</text>
    <view class="close-button" bindtap="closeProfileSheet">×</view>
  </view>

  <view class="avatar-preview {{gender ? '' : 'avatar-empty'}}" catchtap="chooseAvatar">
    <image wx:if="{{avatarUrl}}" class="avatar" src="{{avatarUrl}}" mode="aspectFill" catchtap="chooseAvatar"></image>
    <text wx:else class="avatar-placeholder" catchtap="chooseAvatar">?</text>
    <view class="avatar-edit-badge" catchtap="chooseAvatar">
      <image class="avatar-edit-icon" src="/assets/edit.svg" mode="aspectFit" catchtap="chooseAvatar"></image>
    </view>
    <view class="avatar-upload-mask" wx:if="{{isUploadingAvatar}}">
      <text class="avatar-upload-text">上传中</text>
    </view>
  </view>

  <view class="form">
    <view class="field">
      <text class="label">性别</text>
      <view class="gender-grid">
        <button class="gender-option {{gender === 'male' ? 'gender-active' : ''}}" data-gender="male" bindtap="selectGender">
          <image class="gender-avatar" src="{{maleAvatarUrl}}" mode="aspectFill"></image>
          <image class="gender-icon gender-icon-male" src="/assets/gender-male.svg" mode="aspectFit"></image>
        </button>
        <button class="gender-option {{gender === 'female' ? 'gender-active' : ''}}" data-gender="female" bindtap="selectGender">
          <image class="gender-avatar" src="{{femaleAvatarUrl}}" mode="aspectFill"></image>
          <image class="gender-icon gender-icon-female" src="/assets/gender-female.svg" mode="aspectFit"></image>
        </button>
      </view>
      <text class="error" wx:if="{{genderError}}">{{genderError}}</text>
    </view>

    <view class="field">
      <text class="label">昵称</text>
      <input
        class="input"
        type="nickname"
        value="{{nickName}}"
        placeholder="怎么称呼你"
        placeholder-class="placeholder"
        bindinput="handleNickNameInput"
      />
      <text class="error" wx:if="{{nickNameError}}">{{nickNameError}}</text>
    </view>

    <view class="field">
      <text class="label">SteamID</text>
      <input
        class="input"
        value="{{steamId}}"
        placeholder="输入 SteamID"
        placeholder-class="placeholder"
        bindinput="handleSteamIdInput"
      />
      <text class="error" wx:if="{{steamIdError}}">{{steamIdError}}</text>
    </view>
  </view>

  <button class="primary-button sheet-submit" loading="{{isSaving}}" disabled="{{isSaving}}" bindtap="saveProfile">
    {{isSaving ? '保存中...' : '保存并继续'}}
  </button>
</view>

<view class="sheet-mask" wx:if="{{showCreateSheet}}" bindtap="closeCreateSheet"></view>
<view class="profile-sheet create-sheet" wx:if="{{showCreateSheet}}">
  <view class="sheet-handle"></view>
  <view class="sheet-title-row">
    <text class="sheet-title">{{editingTakeoverId ? '编辑接龙' : '创建接龙'}}</text>
    <view class="close-button" bindtap="closeCreateSheet">×</view>
  </view>

  <scroll-view class="create-scroll" scroll-y>
    <view class="form">
      <view class="field">
        <text class="label">标题</text>
        <input
          class="input"
          value="{{createTitle}}"
          placeholder="例如：周末合作游戏局"
          placeholder-class="placeholder"
          bindinput="handleCreateTitleInput"
        />
        <text class="error" wx:if="{{createTitleError}}">{{createTitleError}}</text>
      </view>

      <view class="field">
        <text class="label">人数上限</text>
        <input
          class="input"
          type="number"
          value="{{createLimit}}"
          placeholder="例如：4"
          placeholder-class="placeholder"
          bindinput="handleCreateLimitInput"
        />
        <text class="error" wx:if="{{createLimitError}}">{{createLimitError}}</text>
      </view>

      <view class="field">
        <text class="label">时间类型</text>
        <view class="schedule-grid">
          <view class="schedule-option {{createScheduleType === 'once' ? 'schedule-active' : ''}}" data-type="once" bindtap="selectScheduleType">指定日期</view>
          <view class="schedule-option {{createScheduleType === 'daily' ? 'schedule-active' : ''}}" data-type="daily" bindtap="selectScheduleType">每天</view>
          <view class="schedule-option {{createScheduleType === 'range' ? 'schedule-active' : ''}}" data-type="range" bindtap="selectScheduleType">日期范围</view>
        </view>
      </view>

      <view class="field" wx:if="{{createScheduleType === 'once'}}">
        <text class="label">指定日期</text>
        <picker mode="date" value="{{createDate}}" start="{{todayDate}}" bindchange="handleCreateDateChange">
          <view class="input picker-input {{createDate ? '' : 'picker-placeholder'}}">{{createDate || '选择日期'}}</view>
        </picker>
        <text class="error" wx:if="{{createDateError}}">{{createDateError}}</text>
      </view>

      <view class="field" wx:elif="{{createScheduleType === 'range'}}">
        <text class="label">日期范围</text>
        <view class="range-row">
          <picker class="range-input" mode="date" value="{{createStartDate}}" start="{{todayDate}}" bindchange="handleCreateStartDateChange">
            <view class="input range-input-inner {{createStartDate ? '' : 'picker-placeholder'}}">{{createStartDate || '开始'}}</view>
          </picker>
          <text class="range-separator">至</text>
          <picker class="range-input" mode="date" value="{{createEndDate}}" start="{{createStartDate || todayDate}}" bindchange="handleCreateEndDateChange">
            <view class="input range-input-inner {{createEndDate ? '' : 'picker-placeholder'}}">{{createEndDate || '结束'}}</view>
          </picker>
        </view>
        <text class="error" wx:if="{{createDateError}}">{{createDateError}}</text>
      </view>

      <view class="field">
        <text class="label">固定时间</text>
        <picker mode="time" value="{{createTime}}" start="{{minCreateTime}}" bindchange="handleCreateTimeChange">
          <view class="input picker-input {{createTime ? '' : 'picker-placeholder'}}">{{createTime || '选择时间'}}</view>
        </picker>
        <text class="error" wx:if="{{createTimeError}}">{{createTimeError}}</text>
      </view>

      <view class="field">
        <text class="label">介绍</text>
        <textarea
          class="textarea"
          value="{{createDescription}}"
          placeholder="简单说说怎么玩、适合什么人"
          placeholder-class="placeholder"
          maxlength="80"
          bindinput="handleCreateDescriptionInput"
        />
        <text class="error" wx:if="{{createDescriptionError}}">{{createDescriptionError}}</text>
      </view>
    </view>
  </scroll-view>

  <button class="primary-button sheet-submit" loading="{{isSubmittingTakeover}}" disabled="{{isSubmittingTakeover}}" bindtap="submitCreateTakeover">
    {{isSubmittingTakeover ? (editingTakeoverId ? '保存中...' : '发布中...') : (editingTakeoverId ? '保存修改' : '发布接龙')}}
  </button>
</view>

<view class="sheet-mask" wx:if="{{showDetailSheet}}" bindtap="closeDetailSheet"></view>
<view class="profile-sheet detail-sheet" wx:if="{{showDetailSheet && currentTakeover}}">
  <view class="sheet-handle"></view>
  <view class="sheet-title-row">
    <view class="detail-title-copy">
      <text class="sheet-title">{{currentTakeover.title}}</text>
      <text class="detail-subtitle">{{currentTakeover.scheduleText}}</text>
    </view>
    <view class="close-button" bindtap="closeDetailSheet">×</view>
  </view>

  <view class="detail-summary">
    <text class="detail-description">{{currentTakeover.description}}</text>
    <view class="detail-count">
      <text class="detail-count-value">{{currentTakeover.joined}}/{{currentTakeover.limit}}</text>
      <text class="detail-count-label">{{detailJoinStatusText}}</text>
    </view>
  </view>

  <scroll-view class="member-scroll" scroll-y>
    <view class="member-list">
      <view class="member-row {{!isAdmin ? 'member-row-user' : ''}}" wx:for="{{currentTakeover.participants}}" wx:key="steamId">
        <image class="detail-avatar" src="{{item.avatarUrl}}" mode="aspectFill"></image>
        <view class="member-info">
          <text class="member-name">{{item.nickName}}</text>
          <view class="member-steam-line">
            <text class="member-steam">SteamID：{{item.steamId}}</text>
            <button class="copy-button" wx:if="{{!isAdmin}}" data-steamid="{{item.steamId}}" bindtap="copySteamId">复制</button>
          </view>
        </view>
        <view class="member-actions" wx:if="{{isAdmin}}">
          <button class="block-button" data-userid="{{item.userId}}" data-steamid="{{item.steamId}}" bindtap="blockUser">拉黑</button>
        </view>
      </view>
    </view>
  </scroll-view>

  <button class="detail-join-button" wx:if="{{showDetailJoinButton}}" bindtap="joinCurrentTakeover">加入接龙</button>
</view>
