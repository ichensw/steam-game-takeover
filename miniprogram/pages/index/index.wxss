page {
  min-height: 100vh;
  background: #0f1118;
  color: #f7f8ff;
}

button::after {
  border: 0;
}

.page {
  height: 100vh;
  overflow: hidden;
  background:
    radial-gradient(circle at 18% 4%, rgba(139, 92, 246, 0.22) 0, rgba(139, 92, 246, 0) 34%),
    radial-gradient(circle at 88% 16%, rgba(45, 212, 191, 0.16) 0, rgba(45, 212, 191, 0) 28%),
    #0f1118;
}

.shell {
  padding: 176rpx 32rpx 128rpx;
  box-sizing: border-box;
}

.topbar {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.brand-copy {
  min-width: 0;
  flex: 1;
}

.title,
.subtitle,
.helper-kicker,
.helper-text,
.card-title,
.card-time,
.limit-value,
.note-text,
.sheet-title,
.label,
.error,
.gender-label {
  display: block;
}

.title {
  color: #f7f8ff;
  font-size: 40rpx;
  line-height: 1.2;
  font-weight: 700;
  letter-spacing: 0;
}

.subtitle {
  margin-top: 10rpx;
  color: rgba(247, 248, 255, 0.58);
  font-size: 24rpx;
  font-weight: 400;
}

.create-button {
  width: 188rpx;
  height: 58rpx;
  margin: 0;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #8b5cf6 0%, #ec4899 100%);
  color: #ffffff;
  font-size: 24rpx;
  line-height: 58rpx;
  font-weight: 600;
  letter-spacing: 0;
  box-shadow: 0 12rpx 24rpx rgba(236, 72, 153, 0.2);
}

.helper-card {
  display: flex;
  align-items: center;
  gap: 22rpx;
  padding: 24rpx;
  margin-bottom: 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.22) 0%, rgba(45, 212, 191, 0.12) 100%);
  box-shadow: 0 18rpx 48rpx rgba(0, 0, 0, 0.22);
}

.helper-avatar {
  width: 86rpx;
  height: 86rpx;
  flex-shrink: 0;
  border-radius: 28rpx;
}

.helper-copy {
  min-width: 0;
}

.helper-kicker {
  color: rgba(247, 248, 255, 0.56);
  font-size: 23rpx;
  font-weight: 500;
}

.helper-text {
  margin-top: 6rpx;
  color: #f7f8ff;
  font-size: 28rpx;
  line-height: 1.35;
  font-weight: 600;
}

.filter-panel {
  margin-bottom: 26rpx;
}

.search-box {
  height: 76rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 0 22rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.06);
  box-sizing: border-box;
}

.search-icon {
  flex-shrink: 0;
  color: rgba(247, 248, 255, 0.44);
  font-size: 30rpx;
}

.search-input {
  min-width: 0;
  flex: 1;
  color: #f7f8ff;
  font-size: 26rpx;
}

.search-clear {
  width: 42rpx;
  height: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
  color: rgba(247, 248, 255, 0.62);
  font-size: 28rpx;
}

.time-filter-list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0;
  width: 100%;
  padding: 6rpx;
  margin-top: 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.06);
  box-sizing: border-box;
}

.time-filter {
  width: 100%;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 0 22rpx;
  border-radius: 16rpx;
  background: transparent;
  box-sizing: border-box;
  color: rgba(247, 248, 255, 0.58);
  font-size: 24rpx;
  font-weight: 500;
  letter-spacing: 0;
}

.time-filter-active {
  background: rgba(45, 212, 191, 0.16);
  color: #9cf5e8;
}

.time-filter-select {
  border-left: 1rpx solid rgba(255, 255, 255, 0.08);
}

.time-filter-active + .time-filter-select,
.time-filter-select.time-filter-active {
  border-left-color: transparent;
}

.filter-caret {
  width: 0;
  height: 0;
  border-right: 8rpx solid transparent;
  border-left: 8rpx solid transparent;
  border-top: 10rpx solid rgba(247, 248, 255, 0.48);
  transition: transform 0.18s ease;
}

.filter-caret-open {
  transform: rotate(180deg);
}

.time-dropdown {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 14rpx;
  padding: 14rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  background: rgba(24, 27, 37, 0.96);
}

.time-dropdown-item {
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  color: rgba(247, 248, 255, 0.64);
  font-size: 24rpx;
  font-weight: 500;
}

.time-dropdown-active {
  background: rgba(45, 212, 191, 0.16);
  color: #9cf5e8;
}

.range-filter-panel {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 14rpx;
}

.range-picker {
  min-width: 0;
  height: 66rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  padding: 0 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.05);
  box-sizing: border-box;
}

.range-picker-label {
  flex-shrink: 0;
  color: rgba(247, 248, 255, 0.46);
  font-size: 22rpx;
}

.range-picker-value {
  min-width: 0;
  color: #f7f8ff;
  font-size: 24rpx;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.range-clear {
  grid-column: 1 / -1;
  height: 54rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.05);
  color: rgba(247, 248, 255, 0.58);
  font-size: 23rpx;
  font-weight: 500;
}

.takeover-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.takeover-card {
  position: relative;
  padding: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.07);
  border-radius: 22rpx;
  background: #181b25;
  box-shadow: 0 18rpx 42rpx rgba(0, 0, 0, 0.2);
  overflow: hidden;
}

.card-more {
  position: absolute;
  top: 22rpx;
  right: 22rpx;
  z-index: 2;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 5rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.07);
}

.more-dot {
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: rgba(247, 248, 255, 0.72);
}

.card-more:active {
  opacity: 0.74;
}

.card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.card-title {
  min-width: 0;
  flex: 1;
  color: #f7f8ff;
  font-size: 31rpx;
  line-height: 1.28;
  font-weight: 600;
}

.card-time {
  flex-shrink: 0;
  max-width: 260rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(45, 212, 191, 0.14);
  color: #9cf5e8;
  font-size: 23rpx;
  line-height: 1.25;
  font-weight: 500;
  text-align: right;
}

.card-time-admin {
  margin-right: 56rpx;
}

.card-note {
  margin-top: 18rpx;
}

.note-text {
  min-width: 0;
  color: rgba(247, 248, 255, 0.58);
  font-size: 24rpx;
  line-height: 1.45;
  font-weight: 400;
}

.card-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 24rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
}

.member-side {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
  overflow: hidden;
}

.member-side:active {
  opacity: 0.76;
}

.avatar-stack {
  flex: 0 1 124rpx;
  display: flex;
  align-items: center;
  min-width: 0;
  max-width: 124rpx;
  padding-left: 12rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.member-avatar,
.more-avatar {
  width: 44rpx;
  height: 44rpx;
  margin-left: -12rpx;
  border: 3rpx solid #181b25;
  border-radius: 50%;
  background: #2a2f3d;
  box-sizing: border-box;
}

.more-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(247, 248, 255, 0.78);
  font-size: 18rpx;
  font-weight: 600;
}

.limit-value {
  flex: 0 0 auto;
  max-width: 96rpx;
  color: #f7f8ff;
  font-size: 26rpx;
  line-height: 1;
  font-weight: 600;
  white-space: nowrap;
  text-align: left;
}

.join-button {
  width: 148rpx;
  min-width: 148rpx;
  height: 56rpx;
  margin: 0;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 999rpx;
  background: #f7f8ff;
  color: #0f1118;
  font-size: 24rpx;
  line-height: 56rpx;
  font-weight: 600;
  letter-spacing: 0;
  box-shadow: 0 10rpx 24rpx rgba(247, 248, 255, 0.08);
}

.joined-button {
  background: rgba(255, 255, 255, 0.1);
  color: rgba(247, 248, 255, 0.86);
}

.empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 240rpx;
  color: rgba(247, 248, 255, 0.46);
  font-size: 26rpx;
}

.list-footer {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 112rpx;
  padding-bottom: 28rpx;
  box-sizing: border-box;
  color: rgba(247, 248, 255, 0.46);
  font-size: 24rpx;
  font-weight: 400;
}

.load-more-button {
  height: 54rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
  color: rgba(247, 248, 255, 0.72);
  font-size: 24rpx;
  font-weight: 500;
}

.admin-float {
  position: fixed;
  left: 32rpx;
  bottom: calc(34rpx + env(safe-area-inset-bottom));
  z-index: 8;
  width: 78rpx;
  height: 78rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 50%;
  background: rgba(24, 27, 37, 0.9);
  color: rgba(247, 248, 255, 0.58);
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.22);
  backdrop-filter: blur(12rpx);
}

.admin-float-active {
  border-color: rgba(45, 212, 191, 0.28);
  background: rgba(45, 212, 191, 0.14);
}

.admin-float-icon {
  width: 42rpx;
  height: 42rpx;
  display: block;
}

.global-loading {
  position: fixed;
  inset: 0;
  z-index: 9;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.loading-card {
  min-width: 168rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 0 26rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 22rpx;
  background: rgba(24, 27, 37, 0.92);
  box-shadow: 0 18rpx 42rpx rgba(0, 0, 0, 0.28);
  box-sizing: border-box;
}

.loading-spinner {
  width: 30rpx;
  height: 30rpx;
  border: 4rpx solid rgba(247, 248, 255, 0.18);
  border-top-color: #9cf5e8;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.loading-text {
  color: rgba(247, 248, 255, 0.82);
  font-size: 24rpx;
  font-weight: 600;
}

@keyframes spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}

.sheet-mask {
  position: fixed;
  inset: 0;
  z-index: 10;
  background: rgba(0, 0, 0, 0.58);
}

.profile-sheet {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 11;
  padding: 18rpx 32rpx 48rpx;
  border-radius: 36rpx 36rpx 0 0;
  background: #181b25;
  box-sizing: border-box;
}

.create-sheet {
  max-height: 88vh;
}

.detail-sheet {
  max-height: 82vh;
}

.admin-sheet {
  max-height: 60vh;
}

.card-menu-sheet {
  max-height: 48vh;
}

.create-scroll {
  max-height: 58vh;
}

.member-scroll {
  max-height: 48vh;
}

.detail-join-button {
  width: 100%;
  height: 82rpx;
  margin: 22rpx 0 0;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #8b5cf6 0%, #ec4899 100%);
  color: #ffffff;
  font-size: 28rpx;
  line-height: 82rpx;
  font-weight: 700;
  letter-spacing: 0;
  box-shadow: 0 10rpx 22rpx rgba(236, 72, 153, 0.18);
}

.sheet-handle {
  width: 72rpx;
  height: 8rpx;
  margin: 0 auto 28rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
}

.sheet-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 26rpx;
}

.sheet-title {
  color: #f7f8ff;
  font-size: 32rpx;
  line-height: 1.3;
  font-weight: 600;
}

.close-button {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
  color: rgba(247, 248, 255, 0.72);
  font-size: 34rpx;
  line-height: 1;
  font-weight: 500;
}

.avatar-preview {
  width: 128rpx;
  height: 128rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 0 28rpx;
  overflow: hidden;
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.08);
}

.avatar-empty {
  border: 2rpx dashed rgba(255, 255, 255, 0.18);
}

.avatar {
  width: 128rpx;
  height: 128rpx;
  display: block;
}

.avatar-placeholder {
  color: rgba(247, 248, 255, 0.5);
  font-size: 42rpx;
  font-weight: 800;
}

.form {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.gender-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.schedule-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 0;
  padding: 6rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.05);
}

.schedule-option {
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  background: transparent;
  color: rgba(247, 248, 255, 0.64);
  font-size: 24rpx;
  font-weight: 500;
  letter-spacing: 0;
}

.schedule-active {
  background: rgba(45, 212, 191, 0.14);
  color: #9cf5e8;
}

.range-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.range-input {
  min-width: 0;
  flex: 1;
}

.picker-input,
.range-input-inner {
  display: flex;
  align-items: center;
  color: #f7f8ff;
}

.picker-placeholder {
  color: rgba(247, 248, 255, 0.38);
}

.range-separator {
  flex-shrink: 0;
  color: rgba(247, 248, 255, 0.5);
  font-size: 24rpx;
}

.gender-option {
  height: 154rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 0 18rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.05);
}

.gender-active {
  border-color: #8b5cf6;
  background: rgba(139, 92, 246, 0.16);
  box-shadow: 0 10rpx 26rpx rgba(139, 92, 246, 0.16);
}

.gender-avatar {
  width: 92rpx;
  height: 92rpx;
  flex-shrink: 0;
  border-radius: 26rpx;
}

.gender-label {
  color: #f7f8ff;
  font-size: 27rpx;
  font-weight: 500;
}

.label {
  color: rgba(247, 248, 255, 0.82);
  font-size: 25rpx;
  font-weight: 500;
}

.input {
  height: 92rpx;
  padding: 0 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.05);
  box-sizing: border-box;
  color: #f7f8ff;
  font-size: 29rpx;
}

.textarea {
  width: 100%;
  min-height: 150rpx;
  padding: 22rpx 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.05);
  box-sizing: border-box;
  color: #f7f8ff;
  font-size: 29rpx;
  line-height: 1.45;
}

.placeholder {
  color: rgba(247, 248, 255, 0.38);
}

.error {
  color: #fb7185;
  font-size: 23rpx;
}

.primary-button {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #8b5cf6 0%, #ec4899 100%);
  color: #ffffff;
  font-size: 29rpx;
  font-weight: 600;
  letter-spacing: 0;
  box-shadow: 0 10rpx 22rpx rgba(236, 72, 153, 0.18);
}

.card-menu-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.menu-action-button {
  height: 76rpx;
  margin: 0;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.08);
  color: rgba(247, 248, 255, 0.82);
  font-size: 26rpx;
  line-height: 76rpx;
  font-weight: 600;
}

.menu-danger-button {
  background: rgba(251, 113, 133, 0.14);
  color: #fb7185;
}

.detail-title-copy {
  min-width: 0;
  flex: 1;
}

.detail-subtitle {
  display: block;
  margin-top: 8rpx;
  color: #9cf5e8;
  font-size: 24rpx;
  line-height: 1.25;
  font-weight: 500;
}

.detail-summary {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 112rpx;
  gap: 18rpx;
  align-items: center;
  padding: 22rpx;
  margin-bottom: 22rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.05);
}

.detail-description {
  color: rgba(247, 248, 255, 0.72);
  font-size: 25rpx;
  line-height: 1.45;
}

.detail-count {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.detail-count-value {
  color: #f7f8ff;
  font-size: 30rpx;
  line-height: 1;
  font-weight: 700;
}

.detail-count-label {
  color: rgba(247, 248, 255, 0.46);
  font-size: 22rpx;
}

.member-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding-bottom: 12rpx;
}

.member-row {
  display: grid;
  grid-template-columns: 72rpx minmax(0, 1fr) 68rpx;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.07);
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.045);
}

.detail-avatar {
  width: 72rpx;
  height: 72rpx;
  flex-shrink: 0;
  border-radius: 22rpx;
