}

/* Search icon and clear icon are mutually exclusive and centered */
.search-clear {
  width: 58rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  padding: 0;
  border-radius: 50%;
  background: rgba(255, 105, 188, 0.18);
  color: #ff5aac;
  font-size: 38rpx;
  line-height: 58rpx;
  font-weight: 700;
  text-align: center;
  box-sizing: border-box;
}

/* Smaller precise clear icon */
.search-clear {
  position: relative;
  width: 48rpx;
  height: 48rpx;
  padding: 0;
  font-size: 0;
  line-height: 0;
}

.search-clear-line {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 22rpx;
  height: 5rpx;
  border-radius: 999rpx;
  background: #ff5aac;
  transform-origin: center;
}

.search-clear-line-a {
  transform: translate(-50%, -50%) rotate(45deg);
}

.search-clear-line-b {
  transform: translate(-50%, -50%) rotate(-45deg);
}

