/* Status cutout card layer */
.takeover-card {
  min-height: 334rpx;
  padding: 26rpx 28rpx 28rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.58);
  border-radius: 34rpx;
  background: linear-gradient(135deg, rgba(255, 245, 255, 0.82) 0%, rgba(255, 226, 251, 0.5) 58%, rgba(122, 70, 255, 0.16) 100%);
  box-shadow: 0 22rpx 42rpx rgba(34, 7, 110, 0.34), 0 0 30rpx rgba(255, 105, 219, 0.35);
  backdrop-filter: blur(10rpx);
}

.takeover-card::before {
  content: '';
  position: absolute;
  top: 18rpx;
  left: 18rpx;
  bottom: 18rpx;
  z-index: 0;
  width: 62%;
  border-radius: 26rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.86) 0%, rgba(255, 245, 255, 0.64) 100%);
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.54);
}

.takeover-card-pink {
  background: linear-gradient(135deg, rgba(255, 245, 255, 0.84) 0%, rgba(255, 225, 250, 0.56) 55%, rgba(255, 87, 190, 0.18) 100%);
}

.takeover-card-orange {
  background: linear-gradient(135deg, rgba(255, 249, 255, 0.84) 0%, rgba(255, 238, 250, 0.54) 52%, rgba(255, 173, 58, 0.2) 100%);
}

.takeover-card-purple {
  background: linear-gradient(135deg, rgba(255, 247, 255, 0.84) 0%, rgba(247, 235, 255, 0.54) 52%, rgba(138, 92, 255, 0.22) 100%);
}

