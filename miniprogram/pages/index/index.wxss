page {
  min-height: 100vh;
  background: #f7c5f7;
  color: #351556;
}

button::after {
  border: 0;
}

.page {
  position: relative;
  height: 100vh;
  overflow: hidden;
  background: #f7c5f7;
}

.page-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background: linear-gradient(145deg, #ffb7eb 0%, #b58aff 48%, #73d8ff 100%);
  z-index: 0;
  pointer-events: none;
}

.shell {
  position: relative;
  z-index: 1;
  padding: 420rpx 32rpx 160rpx;
  box-sizing: border-box;
}

.topbar {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.brand-copy {
  min-width: 0;
  flex: 1;
}

.title,
.subtitle,
.helper-kicker,
.helper-text,
.card-title,
.card-time,
.limit-value,
.note-text,
.sheet-title,
.label,
.error {
  display: block;
}

.title {
  color: #ffffff;
  font-size: 40rpx;
  line-height: 1.2;
  font-weight: 700;
  letter-spacing: 0;
}

.subtitle {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 24rpx;
  font-weight: 400;
}

.create-button {
  width: 188rpx;
  height: 58rpx;
  margin: 0;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ff70c8 0%, #8c57ff 100%);
  color: #ffffff;
  font-size: 24rpx;
  line-height: 58rpx;
  font-weight: 600;
  letter-spacing: 0;
  box-shadow: 0 12rpx 24rpx rgba(236, 72, 153, 0.2);
}

.helper-card {
  display: flex;
  align-items: center;
  gap: 22rpx;
  padding: 24rpx;
  margin-bottom: 30rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.68);
  border-radius: 30rpx;
  background: rgba(255, 238, 255, 0.72);
  box-shadow: 0 16rpx 36rpx rgba(147, 71, 214, 0.24);
}

.helper-avatar {
  width: 86rpx;
  height: 86rpx;
  flex-shrink: 0;
  border-radius: 28rpx;
}

.helper-copy {
  min-width: 0;
}

.helper-kicker {
  color: #aa6ee8;
  font-size: 23rpx;
  font-weight: 500;
}

.helper-text {
  margin-top: 6rpx;
  color: #351556;
  font-size: 28rpx;
  line-height: 1.35;
  font-weight: 600;
}

.filter-panel {
  margin-bottom: 26rpx;
}

.search-box {
  height: 76rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 0 22rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.68);
  border-radius: 999rpx;
  background: rgba(255, 244, 255, 0.76);
  box-sizing: border-box;
}

.search-icon {
  flex-shrink: 0;
  color: #b172f1;
  font-size: 30rpx;
  margin-bottom: 10rpx;
}

.search-input {
  min-width: 0;
  flex: 1;
  color: #351556;
  font-size: 26rpx;
}

.search-clear {
  width: 42rpx;
  height: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 50%;
  background: rgba(255, 112, 200, 0.16);
  color: #ff70c8;
  font-size: 28rpx;
}

.time-filter-list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0;
  width: 100%;
  padding: 6rpx;
  margin-top: 18rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.68);
  border-radius: 22rpx;
  background: rgba(255, 244, 255, 0.72);
  box-sizing: border-box;
}

.time-filter {
  width: 100%;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 0 22rpx;
  border-radius: 16rpx;
  background: transparent;
  box-sizing: border-box;
  color: #9b66d8;
  font-size: 24rpx;
  font-weight: 500;
  letter-spacing: 0;
}

.time-filter-active {
  background: linear-gradient(135deg, #ff7ccc 0%, #8a5cff 100%);
  color: #ffffff;
}

.time-filter-select {
  border-left: 1rpx solid rgba(173, 105, 227, 0.18);
}

.time-filter-active + .time-filter-select,
.time-filter-select.time-filter-active {
  border-left-color: transparent;
}

.filter-caret {
  width: 0;
  height: 0;
  border-right: 8rpx solid transparent;
  border-left: 8rpx solid transparent;
  border-top: 10rpx solid rgba(92, 44, 145, 0.5);
  transition: transform 0.18s ease;
}

.filter-caret-open {
  transform: rotate(180deg);
}

.time-dropdown {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 14rpx;
  padding: 14rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.68);
  border-radius: 20rpx;
  background: rgba(255, 244, 255, 0.94);
}

.time-dropdown-item {
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  color: #8f5ece;
  font-size: 24rpx;
  font-weight: 500;
}

.time-dropdown-active {
  background: rgba(255, 112, 200, 0.18);
  color: #ff4faf;
}

.range-filter-panel {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 14rpx;
}

.range-filter-panel picker-field {
  min-width: 0;
}

.range-filter-panel .picker-field {
  min-width: 0;
  height: 66rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  padding: 0 18rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.68);
  border-radius: 18rpx;
  background: rgba(255, 244, 255, 0.76);
  box-sizing: border-box;
}

.range-filter-panel .picker-field-text {
  color: #351556;
  font-size: 24rpx;
  font-weight: 500;
  line-height: 66rpx;
}

.range-clear {
  grid-column: 1 / -1;
  height: 54rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  background: rgba(255, 112, 200, 0.14);
  color: #d84fab;
  font-size: 23rpx;
  font-weight: 500;
}

.takeover-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.takeover-card {
  position: relative;
  min-height: 292rpx;
  padding: 34rpx 32rpx 28rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.82);
  border-radius: 34rpx;
  background: linear-gradient(135deg, rgba(255, 249, 255, 0.95) 0%, rgba(255, 232, 252, 0.88) 100%);
  box-shadow:
    0 18rpx 34rpx rgba(133, 74, 205, 0.26),
    0 0 18rpx rgba(255, 131, 219, 0.48);
  overflow: hidden;
}

.takeover-card:active {
  transform: scale(0.992);
}

.card-cover {
  position: absolute;
  right: -22rpx;
  bottom: -12rpx;
  z-index: 0;
  width: 340rpx;
  height: 240rpx;
  opacity: 0.96;
}

.card-glow {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  z-index: 0;
  width: 260rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(255, 118, 204, 0.18);
}

.card-more {
  position: absolute;
  top: 28rpx;
  right: 30rpx;
  z-index: 2;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 5rpx;
  border-radius: 50%;
  background: rgba(255, 112, 200, 0.16);
}

.more-dot {
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: #d95bb7;
}

.card-more:active {
  opacity: 0.74;
}

.card-head {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  width: 58%;
  margin-top: 22rpx;
}

.card-title {
  min-width: 0;
  flex: 1;
  color: #351556;
  font-size: 42rpx;
  line-height: 1.28;
  font-weight: 900;
}

.game-badge,
.status-badge {
  position: relative;
  z-index: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 148rpx;
  height: 50rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  box-sizing: border-box;
  color: #ffffff;
  font-size: 25rpx;
  line-height: 50rpx;
  font-weight: 800;
  box-shadow: 0 8rpx 18rpx rgba(140, 75, 229, 0.24);
}

.game-badge {
  background: linear-gradient(135deg, #7e59ff 0%, #ff66ca 100%);
}

.game-icon {
  margin-right: 8rpx;
  font-size: 24rpx;
}

.status-badge {
  position: absolute;
  top: 28rpx;
  right: 30rpx;
  min-width: 118rpx;
}

.card-more + .game-badge + .status-badge {
  right: 88rpx;
}

.status-pink {
  background: #f86fbd;
}

.status-orange {
  background: #ffb449;
}

.status-purple {
  background: #a77bff;
}

.card-note {
  position: relative;
  z-index: 1;
  width: 58%;
  margin-top: 12rpx;
  padding-bottom: 14rpx;
  border-bottom: 2rpx dashed rgba(172, 113, 226, 0.2);
}

.note-text {
  min-width: 0;
  color: #4f286e;
  font-size: 27rpx;
  line-height: 1.45;
  font-weight: 600;
}

.card-meta-list {
  position: relative;
  z-index: 1;
  width: 52%;
  margin-top: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.card-meta-row {
  display: grid;
  grid-template-columns: 30rpx 120rpx minmax(0, 1fr);
  align-items: center;
  gap: 10rpx;
  min-height: 34rpx;
}

.meta-icon {
  width: 28rpx;
  height: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  color: #ffffff;
  font-size: 18rpx;
  line-height: 28rpx;
}

.meta-time {
  background: #ff70c8;
}

.meta-host {
  background: #a36cff;
}

.meta-count {
  background: #60a8ff;
}

.meta-label {
  color: #b56ceb;
  font-size: 25rpx;
  font-weight: 800;
}

.meta-value {
  min-width: 0;
  color: #351556;
  font-size: 25rpx;
  font-weight: 700;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.tag-list {
  position: relative;
  z-index: 1;
  width: 58%;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.card-tag {
  min-width: 72rpx;
  height: 38rpx;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: rgba(255, 112, 200, 0.2);
  color: #ff4faf;
  font-size: 23rpx;
  font-weight: 800;
}

.card-tag:nth-child(2) {
  background: rgba(142, 101, 255, 0.18);
  color: #8c5dff;
}

.card-tag:nth-child(3) {
  background: rgba(93, 194, 255, 0.22);
  color: #228bdc;
}

.card-foot {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  width: 58%;
  margin-top: 22rpx;
  padding-top: 0;
  border-top: 0;
}

.member-side {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
  overflow: hidden;
}

.member-side:active {
  opacity: 1;
}

.avatar-stack {
  flex: 0 1 124rpx;
  display: flex;
  align-items: center;
  min-width: 0;
  max-width: 124rpx;
  padding-left: 12rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.member-avatar,
.more-avatar {
  width: 44rpx;
  height: 44rpx;
  margin-left: -12rpx;
  border: 3rpx solid #fff6ff;
  border-radius: 50%;
  background: #f4dfff;
  box-sizing: border-box;
}

.more-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8c5dff;
  font-size: 18rpx;
  font-weight: 600;
}

.limit-value {
  flex: 0 0 auto;
  max-width: 96rpx;
  color: #351556;
  font-size: 26rpx;
  line-height: 1;
  font-weight: 600;
  white-space: nowrap;
  text-align: left;
}

.join-button {
  width: 154rpx;
  min-width: 154rpx;
  height: 56rpx;
  margin: 0;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ff7ccc 0%, #8a5cff 100%);
  color: #ffffff;
  font-size: 24rpx;
  line-height: 56rpx;
  font-weight: 600;
  letter-spacing: 0;
  box-shadow: 0 10rpx 24rpx rgba(255, 112, 200, 0.24);
}

.joined-button {
  background: rgba(163, 108, 255, 0.18);
  color: #8c5dff;
}

.empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 240rpx;
  color: rgba(53, 21, 86, 0.6);
  font-size: 26rpx;
}

.list-footer {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 112rpx;
  padding-bottom: 28rpx;
  box-sizing: border-box;
  color: rgba(53, 21, 86, 0.56);
  font-size: 24rpx;
  font-weight: 400;
}

.load-more-button {
  height: 54rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 244, 255, 0.72);
  color: #8c5dff;
  font-size: 24rpx;
  font-weight: 500;
}

.profile-float {
  position: fixed;
  right: 32rpx;
  bottom: calc(34rpx + env(safe-area-inset-bottom));
  z-index: 8;
  width: 104rpx;
  height: 104rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  border: 3rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 50%;
  background: rgba(130, 75, 255, 0.82);
  box-shadow: 0 0 24rpx rgba(255, 108, 219, 0.48), 0 12rpx 28rpx rgba(0, 0, 0, 0.18);
  box-sizing: border-box;
  backdrop-filter: blur(12rpx);
}

.profile-float:active {
  opacity: 0.78;
}

.profile-float-avatar {
  width: 88rpx;
  height: 88rpx;
  flex-shrink: 0;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.78);
  background: rgba(255, 255, 255, 0.1);
  box-sizing: border-box;
}

.credit-float {
  position: absolute;
  top: -10rpx;
  right: -14rpx;
  z-index: 1;
  width: 58rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  background: linear-gradient(135deg, #20c97a 0%, #12b6cb 100%);
  color: #ffffff;
  box-shadow:
    0 12rpx 28rpx rgba(21, 128, 61, 0.26),
    0 0 0 2rpx rgba(255, 255, 255, 0.28),
    inset 0 2rpx 8rpx rgba(255, 255, 255, 0.28);
  box-sizing: border-box;
  backdrop-filter: blur(12rpx);
}

.credit-float-value {
  font-size: 24rpx;
  line-height: 26rpx;
  font-weight: 900;
  letter-spacing: 0;
  text-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.16);
}

.credit-limited {
  background: linear-gradient(135deg, #f59e0b 0%, #f97316 100%);
  box-shadow: 0 12rpx 28rpx rgba(180, 83, 9, 0.24), 0 0 18rpx rgba(245, 158, 11, 0.26);
}

.credit-disabled {
  background: linear-gradient(135deg, #292524 0%, #7f1d1d 100%);
  box-shadow: 0 12rpx 28rpx rgba(17, 24, 39, 0.28), 0 0 18rpx rgba(127, 29, 29, 0.24);
}

.profile-float-copy {
  min-width: 0;
}

.profile-float-name,
.profile-float-meta {
  display: block;
  max-width: 330rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.profile-float-name {
  color: #f7f8ff;
  font-size: 24rpx;
  line-height: 1.25;
  font-weight: 700;
}

.profile-float-meta {
  margin-top: 2rpx;
  color: rgba(247, 248, 255, 0.48);
  font-size: 20rpx;
  line-height: 1.2;
  font-weight: 500;
}

.global-loading {
  position: fixed;
  inset: 0;
  z-index: 9;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.loading-card {
  min-width: 168rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 0 26rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 22rpx;
  background: rgba(24, 27, 37, 0.92);
  box-shadow: 0 18rpx 42rpx rgba(0, 0, 0, 0.28);
  box-sizing: border-box;
}

.loading-spinner {
  width: 30rpx;
  height: 30rpx;
  border: 4rpx solid rgba(247, 248, 255, 0.18);
  border-top-color: #9cf5e8;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.loading-text {
  color: rgba(247, 248, 255, 0.82);
  font-size: 24rpx;
  font-weight: 600;
}

@keyframes spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}

.sheet-mask {
  position: fixed;
  inset: 0;
  z-index: 10;
  background: rgba(0, 0, 0, 0.58);
}

.profile-sheet {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 11;
  padding: 18rpx 32rpx 48rpx;
  border-radius: 36rpx 36rpx 0 0;
  background: #181b25;
  box-sizing: border-box;
}

.create-sheet {
  max-height: 88vh;
}

.detail-sheet {
  max-height: 82vh;
}

.card-menu-sheet {
  max-height: 48vh;
}

.create-scroll {
  max-height: 58vh;
}

.member-scroll {
  max-height: 48vh;
}

.detail-join-button {
  width: 100%;
  height: 82rpx;
  margin: 22rpx 0 0;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #8b5cf6 0%, #ec4899 100%);
  color: #ffffff;
  font-size: 28rpx;
  line-height: 82rpx;
  font-weight: 700;
  letter-spacing: 0;
  box-shadow: 0 10rpx 22rpx rgba(236, 72, 153, 0.18);
}

.sheet-handle {
  width: 72rpx;
  height: 8rpx;
  margin: 0 auto 28rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
}

.sheet-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 26rpx;
}

.sheet-title {
  color: #f7f8ff;
  font-size: 32rpx;
  line-height: 1.3;
  font-weight: 600;
}

.close-button {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
  color: rgba(247, 248, 255, 0.72);
  font-size: 34rpx;
  line-height: 1;
  font-weight: 500;
}

.avatar-preview {
  width: 128rpx;
  height: 128rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 0 28rpx;
  overflow: hidden;
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.08);
}

.avatar-upload-mask {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(10, 13, 24, 0.68);
}

.avatar-upload-text {
  color: rgba(255, 255, 255, 0.9);
  font-size: 22rpx;
  font-weight: 700;
}

.avatar-edit-badge {
  position: absolute;
  right: 8rpx;
  bottom: 8rpx;
  width: 38rpx;
  height: 38rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(255, 255, 255, 0.18);
  border-radius: 50%;
  background: rgba(24, 27, 37, 0.88);
  box-shadow: 0 6rpx 14rpx rgba(0, 0, 0, 0.24);
}

.avatar-edit-icon {
  width: 22rpx;
  height: 22rpx;
  display: block;
}

.avatar-empty {
