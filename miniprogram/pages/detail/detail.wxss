page {
  min-height: 100vh;
  background: #f7c5f7;
  color: #351556;
}

button::after {
  border: 0;
}

.detail-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
}

.detail-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background: linear-gradient(145deg, #ffb7eb 0%, #b58aff 48%, #73d8ff 100%);
  z-index: 0;
  pointer-events: none;
}

.detail-shell {
  position: relative;
  z-index: 1;
  padding: 92rpx 32rpx 176rpx;
  box-sizing: border-box;
}

.detail-nav {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 270rpx;
}

.back-button {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 50%;
  background: rgba(255, 244, 255, 0.74);
  color: #8c5dff;
  font-size: 58rpx;
  line-height: 1;
  font-weight: 500;
  box-shadow: 0 10rpx 24rpx rgba(133, 74, 205, 0.2);
}

.back-icon {
  display: block;
  height: 64rpx;
  line-height: 58rpx;
  transform: translateX(-2rpx);
}

.nav-copy {
  min-width: 0;
}

.nav-title,
.nav-subtitle,
.hero-title,
.hero-desc,
.section-title,
.section-count,
.member-name,
.member-steam {
  display: block;
}

.nav-title {
  color: #ffffff;
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 900;
}

.nav-subtitle {
  margin-top: 6rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 22rpx;
  font-weight: 600;
}

.hero-card,
.member-section {
  position: relative;
  border: 3rpx solid rgba(255, 255, 255, 0.82);
  border-radius: 34rpx;
  background: linear-gradient(135deg, rgba(255, 249, 255, 0.95) 0%, rgba(255, 232, 252, 0.9) 100%);
  box-shadow:
    0 18rpx 34rpx rgba(133, 74, 205, 0.26),
    0 0 18rpx rgba(255, 131, 219, 0.48);
  box-sizing: border-box;
  overflow: hidden;
}

.hero-card {
  min-height: 470rpx;
  padding: 34rpx 32rpx 32rpx;
}

.hero-cover {
  position: absolute;
  right: -20rpx;
  top: 42rpx;
  width: 360rpx;
  height: 260rpx;
  opacity: 0.96;
}

.host-badge {
  position: relative;
  z-index: 2;
  display: inline-flex;
  align-items: center;
  max-width: 260rpx;
  height: 50rpx;
  padding: 0 18rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #7c4dff 0%, #9f5cff 100%);
  color: #ffffff;
  font-size: 24rpx;
  line-height: 50rpx;
  font-weight: 900;
  box-shadow: 0 10rpx 22rpx rgba(124, 76, 255, 0.28);
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.game-badge,
.status-badge {
  position: relative;
  z-index: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 148rpx;
  height: 50rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  box-sizing: border-box;
  color: #ffffff;
  font-size: 25rpx;
  line-height: 50rpx;
  font-weight: 800;
  box-shadow: 0 8rpx 18rpx rgba(140, 75, 229, 0.24);
}

.game-badge {
  background: linear-gradient(135deg, #7e59ff 0%, #ff66ca 100%);
}

.game-icon {
  margin-right: 8rpx;
  font-size: 24rpx;
}

.status-badge {
  position: absolute;
  top: 32rpx;
  right: 32rpx;
  min-width: 118rpx;
}

.status-pink {
  background: #f86fbd;
}

.status-orange {
  background: #ffb449;
}

.status-purple {
  background: #ef4444;
}

.status-ended {
  background: #8b7a9f;
}

.status-ended {
  background: #8f82b8;
}

.hero-title {
  position: relative;
  z-index: 1;
  width: 58%;
  margin-top: 32rpx;
  color: #351556;
  font-size: 48rpx;
  line-height: 1.22;
  font-weight: 900;
}

.info-panel {
  position: relative;
  z-index: 1;
  width: 60%;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 18rpx;
}

.description-section {
  position: relative;
  z-index: 1;
  margin-top: 24rpx;
  padding: 24rpx 28rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 30rpx;
  background: rgba(244, 231, 250, 0.94);
  box-shadow: 0 18rpx 34rpx rgba(34, 7, 110, 0.24), 0 0 22rpx rgba(255, 112, 220, 0.28);
  box-sizing: border-box;
}

.description-title {
  display: block;
  color: #351556;
  font-size: 30rpx;
  line-height: 40rpx;
  font-weight: 900;
}

.description-text {
  display: block;
  margin-top: 12rpx;
  color: #4f286e;
  font-size: 26rpx;
  line-height: 42rpx;
  font-weight: 700;
}

.kook-link-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 108rpx;
  align-items: center;
  gap: 18rpx;
}

.kook-channel-name {
  min-width: 0;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.kook-copy-button {
  width: 108rpx;
}

.kook-guide-text {
  display: block;
  margin-top: 14rpx;
  padding: 14rpx 16rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.56);
  color: #6c3c86;
  font-size: 24rpx;
  line-height: 36rpx;
  font-weight: 700;
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.info-label {
  flex-shrink: 0;
  color: #b56ceb;
  font-size: 25rpx;
  font-weight: 800;
}

.info-value {
  min-width: 0;
  color: #351556;
  font-size: 25rpx;
  font-weight: 800;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.hero-avatar-stack {
  position: relative;
  z-index: 2;
  width: 60%;
  display: flex;
  align-items: center;
  margin-top: 24rpx;
  padding-left: 4rpx;
}

.hero-avatar {
  width: 58rpx;
  height: 58rpx;
  margin-left: -14rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  box-sizing: border-box;
  background: #ffffff;
  box-shadow: 0 8rpx 18rpx rgba(53, 21, 86, 0.18);
}

.hero-avatar:first-child {
  margin-left: 0;
}

.tag-list {
  position: relative;
  z-index: 1;
  width: 62%;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 24rpx;
}

.card-tag {
  min-width: 72rpx;
  height: 38rpx;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: rgba(255, 112, 200, 0.2);
  color: #ff4faf;
  font-size: 23rpx;
  font-weight: 800;
}

.card-tag:nth-child(2) {
  background: rgba(142, 101, 255, 0.18);
  color: #8c5dff;
}

.card-tag:nth-child(3) {
  background: rgba(93, 194, 255, 0.22);
  color: #228bdc;
}

.member-section {
  margin-top: 30rpx;
  padding: 28rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  color: #351556;
  font-size: 32rpx;
  font-weight: 900;
}

.section-count {
  color: #ff4faf;
  font-size: 26rpx;
  font-weight: 900;
}

.member-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.member-row {
  display: grid;
  grid-template-columns: 72rpx minmax(0, 1fr) 76rpx;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.55);
}

.member-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 22rpx;
  background: #f4dfff;
}

.member-info {
  min-width: 0;
}

.member-name {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.member-name {
  color: #351556;
  font-size: 27rpx;
  line-height: 1.25;
  font-weight: 800;
}

.member-steam {
  min-width: 0;
  margin-top: 6rpx;
  color: rgba(53, 21, 86, 0.56);
  font-size: 23rpx;
  line-height: 1.25;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.copy-button {
  width: 72rpx;
  height: 44rpx;
  margin: 0;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: rgba(142, 101, 255, 0.16);
  color: #8c5dff;
  font-size: 21rpx;
  line-height: 44rpx;
  font-weight: 800;
}

.bottom-action {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 5;
  padding: 18rpx 32rpx calc(28rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(247, 197, 247, 0) 0%, rgba(247, 197, 247, 0.96) 38%);
  box-sizing: border-box;
}

.join-button {
  width: 100%;
  height: 88rpx;
  margin: 0;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ff7ccc 0%, #8a5cff 100%);
  color: #ffffff;
  font-size: 30rpx;
  line-height: 88rpx;
  font-weight: 900;
  letter-spacing: 0;
  box-shadow: 0 14rpx 28rpx rgba(255, 112, 200, 0.28);
}

.leave-button {
  background: linear-gradient(135deg, #ff78b7 0%, #ff5f8f 100%);
  box-shadow: 0 14rpx 28rpx rgba(255, 95, 143, 0.28);
}

.join-button-disabled {
  background: rgba(255, 244, 255, 0.78);
  color: rgba(53, 21, 86, 0.5);
  box-shadow: none;
}

.empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 260rpx;
  color: rgba(53, 21, 86, 0.6);
  font-size: 26rpx;
}

.global-loading {
  position: fixed;
  inset: 0;
  z-index: 9;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.loading-card {
  min-width: 168rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 0 26rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 26rpx;
  background: rgba(255, 244, 255, 0.9);
  box-shadow: 0 18rpx 42rpx rgba(133, 74, 205, 0.24);
  box-sizing: border-box;
}

.loading-spinner {
  width: 30rpx;
  height: 30rpx;
  border: 4rpx solid rgba(140, 93, 255, 0.18);
  border-top-color: #ff70c8;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.loading-text {
  color: #8c5dff;
  font-size: 24rpx;
  font-weight: 800;
}

@keyframes spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}

