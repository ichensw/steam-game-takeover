.sheet-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.sheet-title {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 900;
}

.close-button {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.78);
  font-size: 34rpx;
}

.admin-input,
.admin-textarea {
  width: 100%;
  height: 72rpx;
  padding: 0 22rpx;
  display: flex;
  align-items: center;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.08);
  color: #ffffff;
  font-size: 25rpx;
  line-height: 72rpx;
  box-sizing: border-box;
}

.admin-textarea {
  display: block;
  height: 150rpx;
  padding-top: 18rpx;
  line-height: 1.45;
}

.placeholder {
  color: rgba(255, 255, 255, 0.42);
}

.error {
  display: block;
  margin-top: 12rpx;
  color: #fb7185;
  font-size: 23rpx;
}

.sheet-submit {
  width: 100%;
  height: 78rpx;
  margin: 24rpx 0 0;
  padding: 0;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #ff70c8 0%, #8a5cff 100%);
  color: #ffffff;
  font-size: 28rpx;
  line-height: 78rpx;
  font-weight: 900;
}

.edit-scroll {
  max-height: 58vh;
}

.edit-form {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.edit-field {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.edit-label {
  color: rgba(255, 255, 255, 0.78);
  font-size: 24rpx;
  font-weight: 800;
}

.report-title-copy {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.report-target {
  max-width: 540rpx;
  color: rgba(53, 21, 86, 0.52);
  font-size: 23rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.report-textarea {
  height: 210rpx;
  padding: 20rpx 22rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.86);
  color: #351556;
  font-size: 26rpx;
  line-height: 1.45;
  font-weight: 700;
}

.report-placeholder {
  color: rgba(53, 21, 86, 0.36);
}

.remark-textarea {
  height: 190rpx;
  padding: 24rpx 24rpx 50rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow:
    inset 0 2rpx 8rpx rgba(80, 35, 120, 0.05),
    0 8rpx 20rpx rgba(80, 35, 120, 0.06);
}

.remark-count {
  position: absolute;
  right: 22rpx;
  bottom: 16rpx;
  color: rgba(53, 21, 86, 0.42);
  font-size: 22rpx;
  line-height: 30rpx;
  font-weight: 700;
}

.remark-field {
  position: relative;
}

.remark-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.remark-secondary-button,
.remark-primary-button {
  flex: 1 1 0;
  width: 0;
  min-width: 0;
  height: 78rpx;
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  border-radius: 999rpx;
  font-size: 27rpx;
  line-height: 78rpx;
  font-weight: 900;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.remark-secondary-button {
  background: rgba(255, 255, 255, 0.72);
  color: #7c3cff;
  box-shadow: inset 0 0 0 2rpx rgba(140, 92, 255, 0.14);
}

.remark-primary-button {
  color: #ffffff;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.38), rgba(255, 255, 255, 0) 42%),
    linear-gradient(180deg, #ff86d1 0%, #d85cff 52%, #8a5cff 100%);
  box-shadow:
    inset 0 3rpx 0 rgba(255, 255, 255, 0.48),
    inset 0 -8rpx 14rpx rgba(73, 33, 145, 0.22),
    0 14rpx 24rpx rgba(143, 82, 255, 0.2);
}

.report-sheet .sheet-submit {
  height: 82rpx;
  border-radius: 22rpx;
  line-height: 82rpx;
}

.report-sheet .remark-primary-button {
  height: 78rpx;
  margin: 0;
  border-radius: 999rpx;
  color: #ffffff;
  line-height: 78rpx;
}

.create-sheet {
  left: 34rpx;
  right: 34rpx;
  bottom: 24rpx;
  max-height: 88vh;
  padding: 18rpx 28rpx calc(30rpx + env(safe-area-inset-bottom));
  border-radius: 30rpx;
  background: #faebff;
  box-shadow: 0 22rpx 54rpx rgba(39, 12, 96, 0.34);
}

.create-sheet .sheet-handle {
  width: 82rpx;
  margin-bottom: 20rpx;
  background: rgba(124, 60, 255, 0.22);
}

.create-sheet .sheet-title-row {
  margin-bottom: 20rpx;
}

.create-sheet .sheet-title {
  color: #351556;
}

.create-sheet .close-button {
  width: 54rpx;
  height: 54rpx;
  background: rgba(124, 60, 255, 0.12);
  color: #7c3cff;
  font-weight: 700;
}

.create-scroll {
  max-height: 58vh;
}

.create-sheet .form {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.create-sheet .field {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.create-sheet .label {
  color: rgba(53, 21, 86, 0.72);
  font-size: 24rpx;
  font-weight: 800;
}

.create-sheet .input,
.create-sheet .textarea,
.create-sheet picker-field {
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.86);
}

.create-sheet .input,
.create-sheet .textarea {
  width: 100%;
  border: 0;
  color: #351556;
  font-weight: 800;
  box-sizing: border-box;
}

.create-sheet .input,
.create-sheet .picker-input,
.create-sheet .range-input-inner {
  height: 82rpx;
  line-height: 82rpx;
}

.create-sheet .input {
  padding: 0 22rpx;
}

.create-sheet .textarea {
  min-height: 140rpx;
  padding: 18rpx 22rpx;
  line-height: 1.45;
}

.create-sheet .placeholder,
.create-sheet .picker-placeholder {
  color: rgba(53, 21, 86, 0.42);
}

.create-sheet .schedule-grid {
  display: flex;
  justify-content: space-between;
  gap: 14rpx;
  padding: 0;
  border: 0;
  background: transparent;
}

.create-sheet .schedule-option {
  flex: 1;
  height: 82rpx;
  border: 2rpx solid rgba(124, 60, 255, 0.14);
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.72);
  color: rgba(53, 21, 86, 0.66);
}

.create-sheet .schedule-active {
  border-color: rgba(255, 92, 185, 0.82);
  background: rgba(255, 239, 252, 0.96);
  color: #7c3cff;
  box-shadow: 0 10rpx 24rpx rgba(255, 92, 185, 0.16);
}

.create-sheet .range-separator {
  color: rgba(53, 21, 86, 0.58);
  line-height: 82rpx;
}

.create-sheet .sheet-submit {
  height: 82rpx;
  border-radius: 22rpx;
  line-height: 82rpx;
}

.schedule-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 0;
  padding: 6rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.08);
}

.schedule-option {
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  color: rgba(255, 255, 255, 0.64);
  font-size: 24rpx;
  font-weight: 800;
}

.schedule-active {
  background: rgba(255, 112, 200, 0.2);
  color: #ffffff;
}

.range-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.range-input {
  min-width: 0;
  flex: 1;
}

.range-separator {
  flex-shrink: 0;
  color: rgba(255, 255, 255, 0.58);
  font-size: 24rpx;
  line-height: 72rpx;
  font-weight: 800;
}

.picker-input,
.range-input-inner {
  height: 72rpx;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.picker-input,
.range-input-inner {
  width: 100%;
  line-height: 72rpx;
}

/* Member card polish */
.member-section .member-list {
  gap: 16rpx;
}

.member-section .member-row {
  display: grid;
  grid-template-columns: 78rpx minmax(0, 1fr);
  align-items: start;
  gap: 18rpx;
  min-height: 128rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.62);
  border-radius: 24rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.74), rgba(255, 255, 255, 0.52));
}

.member-section .member-avatar {
  width: 78rpx;
  height: 78rpx;
  border-radius: 22rpx;
  box-shadow: 0 8rpx 18rpx rgba(80, 35, 120, 0.12);
}

.member-section .member-content {
  min-width: 0;
  display: grid;
  align-items: center;
  gap: 18rpx;
}

.member-section .member-content-actions {
  grid-template-columns: minmax(0, 1fr) 108rpx;
}

.member-section .member-name-line {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.member-section .member-name {
  min-width: 0;
  max-width: 100%;
  color: #351556;
  font-size: 28rpx;
  line-height: 36rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.member-steam-pill {
  max-width: 100%;
  min-height: 42rpx;
  margin-top: 10rpx;
  padding: 5rpx 14rpx 6rpx;
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  border-radius: 999rpx;
  background: rgba(140, 92, 255, 0.1);
  color: #6f3ab8;
  box-sizing: border-box;
}

.member-steam-empty {
  background: rgba(53, 21, 86, 0.06);
  color: rgba(53, 21, 86, 0.44);
}

.member-steam-label {
  flex-shrink: 0;
  font-size: 20rpx;
  line-height: 28rpx;
  font-weight: 900;
  opacity: 0.76;
}

.member-steam-value {
  min-width: 0;
  font-size: 23rpx;
  line-height: 30rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.member-note-row {
  margin-top: 10rpx;
  display: grid;
  gap: 8rpx;
  justify-items: start;
  min-width: 0;
}

.member-remark-bubble {
  min-width: 0;
  max-width: 100%;
  padding: 10rpx 14rpx;
  display: block;
  align-items: flex-start;
  border-radius: 16rpx;
  background: rgba(255, 112, 200, 0.11);
  color: #6f3ab8;
  box-sizing: border-box;
}

.member-remark-text {
  display: block;
  min-width: 0;
  color: #6f3ab8;
  font-size: 23rpx;
  line-height: 32rpx;
  font-weight: 800;
  word-break: break-all;
}

.member-section .remark-edit-button {
  flex-shrink: 0;
  width: auto;
  min-width: 0;
  height: 46rpx;
  margin: 0;
  padding: 0 18rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: 0;
  border-radius: 999rpx;
  background: rgba(140, 92, 255, 0.12);
  color: #7c3cff;
  font-size: 22rpx;
  line-height: 46rpx;
  font-weight: 900;
  white-space: nowrap;
}

.member-section .remark-add-button {
  border: 2rpx dashed rgba(140, 92, 255, 0.34);
  background: rgba(255, 255, 255, 0.38);
  color: #8c5dff;
}

.member-section .member-actions {
  display: grid;
  grid-auto-flow: row;
  gap: 10rpx;
  justify-items: stretch;
  align-content: center;
}

.member-section .copy-button,
.member-section .report-button {
  width: 108rpx;
  min-width: 108rpx;
  max-width: 108rpx;
  height: 52rpx;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 52rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.member-section .report-button {
  background: rgba(239, 68, 68, 0.08);
  border: 2rpx solid rgba(239, 68, 68, 0.22);
  color: #e54868;
  box-shadow: none;
}

/* Floating primary action */
.detail-shell {
  padding-bottom: calc(220rpx + env(safe-area-inset-bottom));
}

.bottom-action {
  pointer-events: none;
  padding: 0 32rpx calc(30rpx + env(safe-area-inset-bottom));
  background: transparent;
}

.bottom-action .join-button {
  pointer-events: auto;
  width: 348rpx;
  height: 92rpx;
  margin: 0 auto;
  border-radius: 999rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.42), rgba(255, 255, 255, 0) 42%),
    linear-gradient(180deg, #ffb15f 0%, #ff63bd 54%, #9a5cff 100%);
  color: #ffffff;
  line-height: 92rpx;
  text-shadow: 0 2rpx 4rpx rgba(111, 45, 154, 0.2);
  box-shadow:
    inset 0 3rpx 0 rgba(255, 255, 255, 0.5),
    inset 0 -8rpx 14rpx rgba(92, 40, 154, 0.22),
    0 18rpx 30rpx rgba(255, 80, 177, 0.28),
    0 6rpx 0 rgba(132, 63, 204, 0.2);
}

.bottom-action .leave-button {
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.42), rgba(255, 255, 255, 0) 42%),
    linear-gradient(180deg, #ff91c8 0%, #ff5f9f 54%, #ef4b82 100%);
  text-shadow: 0 2rpx 4rpx rgba(151, 29, 78, 0.18);
  box-shadow:
    inset 0 3rpx 0 rgba(255, 255, 255, 0.5),
    inset 0 -8rpx 14rpx rgba(178, 36, 88, 0.22),
    0 18rpx 30rpx rgba(255, 88, 150, 0.28),
    0 6rpx 0 rgba(207, 61, 117, 0.2);
}
