/* Member row grid layout */
.member-row {
  display: grid;
  grid-template-columns: 76rpx minmax(0, 1fr);
  align-items: center;
  gap: 18rpx;
  padding: 18rpx 20rpx;
  overflow: visible;
}

.member-content {
  min-width: 0;
