/* Detail readability fixes */
.hero-card {
  min-height: 380rpx;
}

.hero-title,
.hero-desc,
.info-panel {
  width: 52%;
}

.info-panel {
  gap: 12rpx;
  margin-top: 22rpx;
}

.info-row {
  display: grid;
  grid-template-columns: 118rpx minmax(0, 1fr);
  align-items: start;
  gap: 14rpx;
}

.info-label {
  width: auto;
  line-height: 34rpx;
}

.info-value {
  min-width: 0;
  white-space: normal;
  overflow: visible;
  text-overflow: clip;
  line-height: 34rpx;
}

.member-section {
  background: #f4e7fa;
}

.member-row {
  grid-template-columns: 76rpx minmax(0, 1fr) 104rpx;
  gap: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.58);
  box-shadow: none;
}

.copy-button,
.report-button {
  width: 96rpx;
  min-width: 96rpx;
  height: 52rpx;
  padding: 0;
  opacity: 1;
  background: linear-gradient(135deg, #ff70c8 0%, #8a5cff 100%);
  color: #ffffff;
  font-size: 22rpx;
  line-height: 52rpx;
  text-align: center;
  box-shadow: 0 8rpx 18rpx rgba(140, 92, 255, 0.2);
}

.report-button {
  background: linear-gradient(135deg, #ff5f8f 0%, #ef4444 100%);
  box-shadow: 0 8rpx 18rpx rgba(239, 68, 68, 0.22);
}

.member-steam {
  color: rgba(53, 21, 86, 0.58);
}

/* Keep copy button fully inside member row */
.member-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.member-info {
  flex: 1 1 auto;
  min-width: 0;
}

.member-name-line {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.credit-badge {
  flex-shrink: 0;
  min-width: 48rpx;
  height: 34rpx;
  padding: 0 10rpx;
  border: 1rpx solid rgba(21, 128, 61, 0.14);
  border-radius: 18rpx;
  background: rgba(34, 197, 94, 0.14);
  color: #15803d;
  font-size: 21rpx;
  line-height: 34rpx;
  font-weight: 900;
  text-align: center;
  box-sizing: border-box;
  box-shadow: 0 4rpx 12rpx rgba(21, 128, 61, 0.08);
}

.credit-badge.credit-limited {
  background: rgba(245, 158, 11, 0.16);
  border-color: rgba(180, 83, 9, 0.14);
  color: #b45309;
  box-shadow: 0 4rpx 12rpx rgba(180, 83, 9, 0.08);
}

.credit-badge.credit-disabled {
  background: rgba(127, 29, 29, 0.12);
  border-color: rgba(153, 27, 27, 0.14);
  color: #991b1b;
  box-shadow: 0 4rpx 12rpx rgba(127, 29, 29, 0.08);
}

.copy-button,
.report-button {
  flex: 0 0 108rpx;
  width: 108rpx;
  min-width: 108rpx;
  max-width: 108rpx;
  height: 52rpx;
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

.admin-actions {
  position: relative;
  z-index: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 24rpx;
  width: 100%;
  box-sizing: border-box;
}

.admin-action-button {
  flex: 1 1 220rpx;
  min-width: 0;
  height: 72rpx;
  margin: 0;
  padding: 0 24rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  background: rgba(244, 231, 250, 0.92);
  color: #7b42d6;
  font-size: 26rpx;
  line-height: 1;
  font-weight: 900;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  box-shadow: 0 12rpx 24rpx rgba(34, 7, 110, 0.18);
}

.admin-danger-button {
  background: linear-gradient(135deg, #ff78b7 0%, #ff5f8f 100%);
  color: #ffffff;
}

.sheet-mask {
  position: fixed;
  inset: 0;
  z-index: 10;
  background: rgba(0, 0, 0, 0.48);
}

.admin-sheet {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 11;
  padding: 18rpx 32rpx calc(36rpx + env(safe-area-inset-bottom));
  border-radius: 36rpx 36rpx 0 0;
  background: #20103e;
  box-sizing: border-box;
}

.edit-sheet {
  max-height: 88vh;
}

.report-sheet {
  max-height: 82vh;
}

.sheet-handle {
  width: 72rpx;
  height: 8rpx;
  margin: 0 auto 28rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.22);
}

.sheet-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.sheet-title {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 900;
}

.close-button {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.78);
  font-size: 34rpx;
}

.admin-input,
.admin-textarea {
  width: 100%;
  height: 72rpx;
  padding: 0 22rpx;
  display: flex;
  align-items: center;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.08);
  color: #ffffff;
  font-size: 25rpx;
  line-height: 72rpx;
  box-sizing: border-box;
}

.admin-textarea {
  display: block;
  height: 150rpx;
  padding-top: 18rpx;
  line-height: 1.45;
}

.placeholder {
  color: rgba(255, 255, 255, 0.42);
}

.error {
  display: block;
  margin-top: 12rpx;
  color: #fb7185;
  font-size: 23rpx;
}

.sheet-submit {
  width: 100%;
  height: 78rpx;
  margin: 24rpx 0 0;
  padding: 0;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #ff70c8 0%, #8a5cff 100%);
  color: #ffffff;
  font-size: 28rpx;
  line-height: 78rpx;
  font-weight: 900;
}

.edit-scroll {
  max-height: 58vh;
}

.edit-form {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.edit-field {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.edit-label {
  color: rgba(255, 255, 255, 0.78);
  font-size: 24rpx;
  font-weight: 800;
}

.report-title-copy {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.report-target {
  max-width: 540rpx;
  color: rgba(255, 255, 255, 0.62);
  font-size: 23rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.report-textarea {
  height: 210rpx;
}

.report-image-button {
  width: 100%;
  height: 72rpx;
  margin: 0;
  padding: 0;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.1);
  color: #ffffff;
  font-size: 25rpx;
  line-height: 72rpx;
  font-weight: 800;
}

.report-preview {
  width: 180rpx;
  height: 180rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.08);
}

.schedule-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 0;
  padding: 6rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.08);
}

.schedule-option {
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  color: rgba(255, 255, 255, 0.64);
  font-size: 24rpx;
  font-weight: 800;
}

.schedule-active {
  background: rgba(255, 112, 200, 0.2);
  color: #ffffff;
}

.range-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.range-input {
  min-width: 0;
  flex: 1;
}

.edit-field .picker-field {
  height: 72rpx;
  min-height: 72rpx;
  padding: 0 22rpx;
  font-size: 25rpx;
  line-height: 72rpx;
}

.edit-field .picker-field-text {
  line-height: 72rpx;
}

.range-separator {
  flex-shrink: 0;
  color: rgba(255, 255, 255, 0.58);
  font-size: 24rpx;
  line-height: 72rpx;
  font-weight: 800;
}

.picker-input,
.range-input-inner {
  height: 72rpx;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.picker-input,
.range-input-inner {
  width: 100%;
  line-height: 72rpx;
}
