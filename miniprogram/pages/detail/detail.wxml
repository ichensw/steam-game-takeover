<view class="detail-page">
  <image class="detail-bg" src="https://wechat-bot-images.oss-cn-hangzhou.aliyuncs.com/miniapp/background/tutuwo-neon-bg.png" mode="aspectFill"></image>

  <view class="detail-shell">
    <view class="detail-nav">
      <view class="back-button" bindtap="goBack">
        <text class="back-icon">‹</text>
      </view>
      <view class="nav-copy">
        <text class="nav-title">队伍详情</text>
      </view>
    </view>

    <view class="hero-card" wx:if="{{takeover}}">
      <image class="hero-cover" src="{{takeover.coverImage}}" mode="aspectFit"></image>
      <view class="host-badge">
        <image class="host-badge-icon" src="/assets/icon-gamepad.svg" mode="aspectFit"></image>
        <text class="host-badge-name">{{takeover.host || '兔兔窝'}}</text>
      </view>
      <view class="status-badge status-{{takeover.statusTone}}">{{takeover.statusLabel}}</view>
      <text class="hero-title">{{takeover.title}}</text>

      <view class="info-panel">
        <view class="info-row">
          <text class="info-label">发车时间</text>
          <text class="info-value">{{takeover.scheduleText}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">参与人数</text>
          <text class="info-value">{{takeover.joined}} / {{takeover.limit}}</text>
        </view>
      </view>

      <view class="hero-avatar-stack" wx:if="{{takeover.participantAvatars.length}}">
        <image class="hero-avatar" wx:for="{{takeover.participantAvatars}}" wx:key="*this" src="{{item}}" mode="aspectFill"></image>
      </view>
    </view>

    <view class="description-section" wx:if="{{takeover && takeover.description}}">
      <text class="description-title">队伍介绍</text>
      <text class="description-text">{{takeover.description}}</text>
    </view>

    <view class="description-section kook-section" wx:if="{{takeover && takeover.kookChannelName && takeover.kookInviteUrl}}">
      <text class="description-title">KOOK频道</text>
      <view class="kook-link-row">
        <text class="description-text kook-channel-name">{{takeover.kookChannelName}}</text>
        <button class="copy-button kook-copy-button" bindtap="copyKookInvite">复制</button>
      </view>
      <text class="kook-guide-text">复制链接，用浏览器打开加入 KOOK。建议提前 10 分钟进频道，到点直接集合开局。</text>
    </view>

    <view class="admin-actions" wx:if="{{takeover && canManage && takeover.takeoverState !== 2}}">
      <button class="admin-action-button" bindtap="openEditSheet">编辑</button>
      <button class="admin-action-button admin-danger-button" loading="{{isDeleting}}" disabled="{{isDeleting}}" bindtap="deleteAdminTakeover">删除</button>
    </view>

    <view class="member-section" wx:if="{{takeover}}">
      <view class="section-head">
        <text class="section-title">已上车队友</text>
        <text class="section-count">{{takeover.joined}}/{{takeover.limit}}</text>
      </view>

      <view class="member-list">
        <view class="member-row" wx:for="{{takeover.participants}}" wx:key="userId">
          <image class="member-avatar" src="{{item.avatarUrl}}" mode="aspectFill"></image>
          <view class="member-content {{item.steamId || (takeover.takeoverState === 2 && !item.isSelf) ? 'member-content-actions' : ''}}">
            <view class="member-info">
              <view class="member-name-line">
                <text class="member-name">{{item.nickName}}</text>
                <text class="credit-badge credit-{{item.creditStatus}}">{{item.creditScore}}</text>
              </view>
              <view class="member-steam-pill {{item.steamId ? '' : 'member-steam-empty'}}">
                <text class="member-steam-label">SteamID</text>
                <text class="member-steam-value">{{item.steamId || '未填写'}}</text>
              </view>
              <view class="member-note-row" wx:if="{{item.remark || (item.isSelf && takeover.takeoverState !== 2)}}">
                <view class="member-remark-bubble" wx:if="{{item.remark}}">
                  <text class="member-remark-text">{{item.remark}}</text>
                </view>
                <button class="remark-edit-button {{item.remark ? '' : 'remark-add-button'}}" wx:if="{{item.isSelf && takeover.takeoverState !== 2}}" data-remark="{{item.remark}}" bindtap="openMemberRemarkSheet">{{item.remark ? '编辑备注' : '+ 填写备注'}}</button>
              </view>
            </view>
            <view class="member-actions" wx:if="{{item.steamId || (takeover.takeoverState === 2 && !item.isSelf)}}">
              <button class="copy-button" wx:if="{{item.steamId}}" data-steamid="{{item.steamId}}" bindtap="copySteamId">复制</button>
              <button class="report-button {{!item.canReport ? 'report-button-disabled' : ''}}" wx:if="{{takeover.takeoverState === 2 && !item.isSelf}}" disabled="{{!item.canReport}}" data-reporttype="no_show" data-isself="{{item.isSelf}}" data-userid="{{item.userId}}" data-openid="{{item.openid}}" data-nickname="{{item.nickName}}" bindtap="openReportSheet">{{item.reportStatus}}</button>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="member-section activity-section" wx:if="{{takeover}}" bindtap="openMemberActivities">
      <view class="section-head">
        <text class="section-title">进出记录</text>
        <text class="section-count">{{takeover.memberActivities.length}}</text>
      </view>

      <view class="activity-entry">
        <view class="activity-entry-main" wx:if="{{takeover.memberActivities.length}}">
          <text class="activity-entry-title">{{takeover.memberActivities[0].nickName}} {{takeover.memberActivities[0].actionText}}</text>
          <text class="activity-entry-sub">{{takeover.memberActivities[0].createdAt}}</text>
        </view>
        <view class="activity-entry-main" wx:else>
          <text class="activity-entry-title">暂无进出记录</text>
          <text class="activity-entry-sub">点击查看完整记录</text>
        </view>
        <text class="activity-entry-arrow">›</text>
      </view>
    </view>

    <view class="empty-state" wx:if="{{!takeover && !isLoading && !isAuthorizing}}">
      <text>队伍不存在或已结束</text>
    </view>
  </view>

  <view class="bottom-action" wx:if="{{takeover}}">
    <button
      class="join-button {{hasJoined ? 'leave-button' : ''}} {{!canJoin ? 'join-button-disabled' : ''}}"
      loading="{{isJoining || isLeaving}}"
      disabled="{{!canJoin || isJoining || isLeaving}}"
      bindtap="joinTakeover"
    >
      {{joinButtonText}}
    </button>
  </view>

  <view class="global-loading" wx:if="{{isLoading || isAuthorizing}}">
    <view class="loading-card">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中</text>
    </view>
  </view>

  <profile-sheet
    visible="{{showProfileSheet}}"
    mode="complete"
    nickname="{{nickName}}"
    steam-id="{{steamId}}"
    steam-id-locked="{{steamIdLocked}}"
    gender="{{gender}}"
    avatar-url="{{avatarUrl}}"
    male-avatar-url="{{maleAvatarUrl}}"
    female-avatar-url="{{femaleAvatarUrl}}"
    nickname-error="{{nickNameError}}"
    steam-id-error="{{steamIdError}}"
    gender-error="{{genderError}}"
    is-uploading="{{isUploadingAvatar}}"
    is-saving="{{isSaving}}"
    bindclose="closeProfileSheet"
    bindchooseavatar="chooseAvatar"
    bindselectgender="selectGender"
    bindnicknameinput="handleNickNameInput"
    bindsteamidinput="handleSteamIdInput"
    bindsave="saveProfile"
  />

  <view class="sheet-mask" wx:if="{{showRemarkSheet}}" bindtap="closeMemberRemarkSheet"></view>
  <view class="admin-sheet report-sheet remark-sheet" wx:if="{{showRemarkSheet}}">
    <view class="sheet-handle"></view>
    <view class="sheet-title-row">
      <view class="report-title-copy">
        <text class="sheet-title">{{remarkMode === 'join' ? '加入备注' : '编辑备注'}}</text>
        <text class="report-target">特殊情况可以提前告诉队友</text>
      </view>
      <view class="close-button" bindtap="closeMemberRemarkSheet">×</view>
    </view>

    <view class="edit-form">
      <view class="edit-field remark-field">
        <textarea class="admin-textarea report-textarea remark-textarea" value="{{memberRemark}}" maxlength="100" placeholder="晚到 10 分钟 / 只玩一局 / 麦克风不方便" placeholder-class="report-placeholder" bindinput="handleMemberRemarkInput" />
        <text class="remark-count">{{memberRemark.length}}/100</text>
        <text class="error" wx:if="{{memberRemarkError}}">{{memberRemarkError}}</text>
      </view>
    </view>

    <view class="remark-actions">
      <button class="remark-secondary-button" wx:if="{{remarkMode === 'join'}}" disabled="{{isSavingRemark || isJoining}}" bindtap="joinWithoutRemark">直接加入</button>
      <button class="remark-secondary-button" wx:else disabled="{{isSavingRemark || isJoining}}" bindtap="closeMemberRemarkSheet">取消</button>
      <button class="remark-primary-button" loading="{{isSavingRemark || isJoining}}" disabled="{{isSavingRemark || isJoining}}" bindtap="submitMemberRemark">
        {{isSavingRemark || isJoining ? '保存中...' : remarkMode === 'join' ? '确认加入' : '保存备注'}}
      </button>
    </view>
  </view>

  <view class="sheet-mask" wx:if="{{showEditSheet}}" bindtap="closeEditSheet"></view>
  <view class="admin-sheet create-sheet edit-sheet" wx:if="{{showEditSheet}}">
    <view class="sheet-handle"></view>
    <view class="sheet-title-row">
      <text class="sheet-title">编辑接龙</text>
      <view class="close-button" bindtap="closeEditSheet">×</view>
    </view>

    <scroll-view class="create-scroll" scroll-y>
      <view class="form">
        <view class="field">
          <text class="label">标题</text>
          <input class="input" value="{{editTitle}}" maxlength="30" placeholder="接龙标题" placeholder-class="placeholder" bindinput="handleEditTitleInput" />
        </view>
        <view class="field">
          <text class="label">人数上限</text>
          <input class="input" type="number" value="{{editLimit}}" placeholder="例如：4" placeholder-class="placeholder" bindinput="handleEditLimitInput" />
        </view>
        <view class="field">
          <text class="label">时间类型</text>
          <view class="schedule-grid">
            <view class="schedule-option {{editScheduleType === 'once' ? 'schedule-active' : ''}}" data-type="once" bindtap="selectEditScheduleType">指定日期</view>
            <view class="schedule-option {{editScheduleType === 'daily' ? 'schedule-active' : ''}}" data-type="daily" bindtap="selectEditScheduleType">每天</view>
            <view class="schedule-option {{editScheduleType === 'range' ? 'schedule-active' : ''}}" data-type="range" bindtap="selectEditScheduleType">日期范围</view>
          </view>
        </view>
        <view class="field" wx:if="{{editScheduleType === 'once'}}">
          <text class="label">指定日期</text>
          <picker-field mode="date" theme="light" value="{{editDate}}" start="{{todayDate}}" placeholder="选择日期" bindchange="handleEditDateChange"></picker-field>
        </view>
        <view class="field" wx:elif="{{editScheduleType === 'range'}}">
          <text class="label">日期范围</text>
          <view class="range-row">
            <picker-field class="range-input" mode="date" theme="light" value="{{editStartDate}}" start="{{todayDate}}" placeholder="开始" bindchange="handleEditStartDateChange"></picker-field>
            <text class="range-separator">至</text>
            <picker-field class="range-input" mode="date" theme="light" value="{{editEndDate}}" start="{{editStartDate || todayDate}}" placeholder="结束" bindchange="handleEditEndDateChange"></picker-field>
          </view>
        </view>
        <view class="field">
          <text class="label">固定时间</text>
          <picker-field mode="time" theme="light" value="{{editTime}}" placeholder="选择时间" bindchange="handleEditTimeChange"></picker-field>
        </view>
        <kook-channel-select
          value="{{editKookChannelId}}"
          label="{{editKookChannelSearch}}"
          bindchange="handleEditKookChannelChange"
        />
        <view class="field">
          <text class="label">介绍</text>
          <textarea class="textarea" value="{{editDescription}}" maxlength="500" placeholder="简单说说怎么玩" placeholder-class="placeholder" bindinput="handleEditDescriptionInput" />
        </view>
      </view>
    </scroll-view>

    <button class="sheet-submit" loading="{{isSavingAdmin}}" disabled="{{isSavingAdmin}}" bindtap="saveAdminEdit">
      {{isSavingAdmin ? '保存中...' : '保存修改'}}
    </button>
  </view>

  <view class="sheet-mask" wx:if="{{showReportSheet}}" bindtap="closeReportSheet"></view>
  <view class="admin-sheet report-sheet" wx:if="{{showReportSheet}}">
    <view class="sheet-handle"></view>
    <view class="sheet-title-row">
      <view class="report-title-copy">
        <text class="sheet-title">举报队友</text>
        <text class="report-target">{{reportNickname}}</text>
      </view>
      <view class="close-button" bindtap="closeReportSheet">×</view>
    </view>

    <view class="edit-form">
      <view class="edit-field">
        <text class="edit-label">举报类型</text>
        <view class="report-type-grid">
          <button class="report-type-option {{reportType === item.value ? 'report-type-active' : ''}}" wx:for="{{reportTypes}}" wx:key="value" data-value="{{item.value}}" bindtap="selectReportType">{{item.label}}</button>
        </view>
      </view>
      <view class="edit-field">
        <text class="edit-label">举报内容</text>
        <textarea class="admin-textarea report-textarea" value="{{reportContent}}" maxlength="500" placeholder="请描述违规行为、时间或相关情况" placeholder-class="report-placeholder" bindinput="handleReportContentInput" />
      </view>
      <view class="edit-field">
        <text class="edit-label">举报截图（选填）</text>
        <upload class="report-upload" images="{{reportImageUrls}}" max-count="{{9}}" is-uploading="{{isUploadingReportImage}}" bindchoose="chooseReportImage" bindremove="removeReportImage" bindpreview="previewReportImage" />
      </view>
    </view>

    <button class="sheet-submit" loading="{{isSubmittingReport}}" disabled="{{isSubmittingReport || isUploadingReportImage}}" bindtap="submitReport">
      {{isSubmittingReport ? '提交中...' : '提交举报'}}
    </button>
  </view>
</view>
