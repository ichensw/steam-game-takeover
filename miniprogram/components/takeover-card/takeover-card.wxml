<view class="takeover-card takeover-card-{{takeover.statusTone}}" bindtap="handleTap">
  <image class="card-cover" src="{{takeover.coverImage}}" mode="aspectFit"></image>
  <view class="card-sparkle card-sparkle-one">✦</view>
  <view class="card-sparkle card-sparkle-two">♡</view>
  <view class="status-badge status-{{takeover.statusTone}}">{{takeover.statusLabel}}</view>

  <view class="card-tag-row">
    <view class="creator-badge">
      <image class="creator-icon" src="/assets/icon-gamepad.svg" mode="aspectFit"></image>
      <text class="creator-name">{{takeover.host || takeover.creatorName || '兔兔窝'}}</text>
    </view>
  </view>

  <view class="card-head">
    <text class="card-title">{{takeover.title}}</text>
  </view>

  <view class="card-note">
    <text class="note-text">{{takeover.description}}</text>
  </view>

  <view class="card-meta-list">
    <view class="card-meta-row">
      <view class="meta-icon">
        <image class="meta-icon-image" src="/assets/icon-time.svg" mode="aspectFit"></image>
      </view>
      <text class="meta-value">{{takeover.scheduleText}}</text>
    </view>
    <view class="card-meta-row member-meta-row">
      <view class="meta-icon">
        <image class="meta-icon-image" src="/assets/icon-members.svg" mode="aspectFit"></image>
      </view>
      <text class="meta-value">{{takeover.joinedCount !== undefined ? takeover.joinedCount : takeover.joined}} / {{takeover.participantLimit || takeover.limit}}</text>
    </view>
  </view>

  <view class="card-foot">
    <view class="avatar-stack">
      <image
        class="member-avatar"
        wx:for="{{takeover.participantAvatars}}"
        wx:for-item="avatar"
        wx:key="*this"
        src="{{avatar}}"
        mode="aspectFill"
      ></image>
      <view class="member-avatar member-more" wx:if="{{takeover.participantExtraCount > 0}}">
        +{{takeover.participantExtraCount}}
      </view>
    </view>
    <view class="recommend-tags" wx:if="{{takeover.recommendTags && takeover.recommendTags.length}}">
      <view
        class="recommend-tag recommend-tag-{{tag.tone}}"
        wx:for="{{takeover.recommendTags}}"
        wx:for-item="tag"
        wx:key="type"
      >
        {{tag.label}}
      </view>
    </view>
  </view>
</view>
