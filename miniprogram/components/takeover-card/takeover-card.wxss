.takeover-card {
  position: relative;
  min-height: 286rpx;
  padding: 34rpx 32rpx 24rpx;
  overflow: hidden;
  border: 2rpx solid rgba(255, 255, 255, 0.62);
  border-radius: 34rpx;
  background: rgba(244, 231, 250, 0.78);
  box-shadow: 0 20rpx 38rpx rgba(34, 7, 110, 0.28), 0 0 26rpx rgba(255, 112, 220, 0.28);
  backdrop-filter: blur(16rpx);
  box-sizing: border-box;
}

.takeover-card::after {
  content: '';
  position: absolute;
  inset: 0;
  z-index: 0;
  border-radius: 34rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.24) 0%, rgba(255, 255, 255, 0.06) 48%, rgba(178, 91, 220, 0.08) 100%);
  pointer-events: none;
}

.card-cover {
  position: absolute;
  right: 2rpx;
  bottom: 2rpx;
  z-index: 1;
  width: 286rpx;
  height: 292rpx;
}

.takeover-card-pink .card-cover {
  right: -28rpx;
  bottom: -8rpx;
  width: 354rpx;
  height: 304rpx;
}

.takeover-card-purple .card-cover {
  right: 8rpx;
  bottom: 6rpx;
  width: 262rpx;
  height: 262rpx;
}

.card-sparkle {
  position: absolute;
  z-index: 2;
  color: rgba(255, 116, 212, 0.34);
  font-size: 44rpx;
  font-weight: 900;
}

.card-sparkle-one {
  top: 100rpx;
  right: 300rpx;
}

.card-sparkle-two {
  top: 154rpx;
  right: 216rpx;
}

.status-badge {
  position: absolute;
  top: 32rpx;
  right: 32rpx;
  z-index: 2;
  min-width: 104rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 18rpx;
  border-radius: 18rpx;
  background: #ff9f1a;
  color: #ffffff;
  font-size: 26rpx;
  line-height: 56rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.status-pink {
  background: #ff5cb9;
}

.status-orange {
  background: #ff9f1a;
}

.status-purple {
  background: #ef4444;
}

.status-ended {
  background: #8b7a9f;
}

.card-head,
.card-note,
.card-meta-list,
.card-foot {
  position: relative;
  z-index: 2;
  width: 52%;
}

.creator-badge {
  position: relative;
  z-index: 2;
  max-width: 260rpx;
  height: 56rpx;
  margin-bottom: 18rpx;
  padding: 0 18rpx 0 12rpx;
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #6b35f1 0%, #8c3cff 100%);
  box-shadow: 0 8rpx 16rpx rgba(91, 47, 212, 0.28);
  box-sizing: border-box;
}

.creator-icon {
  color: #ffffff;
  font-size: 32rpx;
  line-height: 1;
}

.creator-name {
  min-width: 0;
  max-width: 180rpx;
  display: block;
  overflow: hidden;
  color: #ffffff;
  font-size: 26rpx;
  line-height: 56rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-title {
  display: block;
  overflow: hidden;
  color: #321855;
  font-size: 38rpx;
  line-height: 1.12;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-note {
  margin-top: 10rpx;
}

.note-text {
  display: block;
  overflow: hidden;
  color: #321855;
  font-size: 24rpx;
  line-height: 32rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-meta-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.card-meta-row {
  min-height: 34rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.meta-icon {
  width: 32rpx;
  height: 32rpx;
  padding: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 50%;
  background: #8655f6;
  box-sizing: border-box;
}

.meta-icon-image {
  width: 20rpx;
  height: 20rpx;
  display: block;
}

.meta-value {
  max-width: 240rpx;
  overflow: hidden;
  color: #321855;
  font-size: 24rpx;
  line-height: 34rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-foot {
  margin-top: 14rpx;
}

.avatar-stack {
  display: flex;
  align-items: center;
  gap: 10rpx;
  max-width: 350rpx;
  overflow: hidden;
}

.member-avatar {
  width: 56rpx;
  height: 56rpx;
  flex-shrink: 0;
  border: 4rpx solid rgba(255, 246, 255, 0.96);
  border-radius: 50%;
  background: #f3ddff;
  box-shadow: 0 6rpx 14rpx rgba(76, 29, 149, 0.16);
}
