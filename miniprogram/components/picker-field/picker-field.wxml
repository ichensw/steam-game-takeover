<picker mode="{{mode}}" value="{{value}}" start="{{start}}" end="{{end}}" bindchange="handleChange">
  <view class="picker-field {{theme === 'light' ? 'picker-field-light' : ''}} {{value ? '' : 'picker-field-placeholder'}}">
    <text class="picker-field-text">{{value || placeholder}}</text>
  </view>
</picker>
