.picker-field {
  width: 100%;
  height: 92rpx;
  min-height: 92rpx;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.08);
  color: #f7f8ff;
  font-size: 26rpx;
  line-height: 92rpx;
  font-weight: 600;
  box-sizing: border-box;
}

.picker-field-text {
  min-width: 0;
  display: block;
  overflow: hidden;
  line-height: 92rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.picker-field-placeholder {
  color: rgba(247, 248, 255, 0.38);
}

.picker-field-light {
  background: rgba(255, 255, 255, 0.86);
  color: #351556;
}

.picker-field-light.picker-field-placeholder {
  color: rgba(53, 21, 86, 0.42);
}
